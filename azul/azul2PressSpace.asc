;; ==[ AZUL2PressSpace ]==================================================
;;
;; All loading is done by loader.
;; So we can start!
;;
;; shows the blinking "Press space to start"
;; and scrolls up to make room for the game :)
    
; shows blinking message and waits for space
    .section .text
    .global Azul2PressSpace

Azul2PressSpace:
    call StopVDP                   ; force stop/reset the vdp, makes sure we're clean
    
    ld c, 32                       ; color-shadow (green)
    call WriteText                 ; we write the text below 212, so its off-screen
    
    ld HL, LOGOTEXT                ; move 1 pixel right and down
    ld a, 1
    ld (HL), a
    inc HL
    ld a, 230+13+1
    ld (HL), a
    
    ld c, 120                      ; color ltters (orange)
    call WriteText                 ; we write the text below 212, so its off-screen
                             ; later we can copy paste it in view with a HMMM action.
    
BlinkLoop:                         ; Wait on V-Blank (Synchronize)
    xor a                          ; Kijk naar Status register 0
    out (VDPC), a                  ; waarde 0
    ld a, 0x8F                     ; 0x8F = Register 15 (Status Pointer)
    out (VDPC), a                  ; de VDP staat nu op SR#0
BlinkWaitLoop:
    in   a,(VDPC)                  ; Wacht nu tot hij weer 0 is
    rlca
    jr  nc, BlinkWaitLoop
    
    
    ; TESTER
    ; ld   a, 0x1C         ; Kleur rood (als je rood ziet missen we frames!)
    ; out  (0x99), a       ; Schrijf data naar VDP register poort
    ; ld   a, 128 + 7     ; 128 = Register schrijven, 7 = Border register
    ; out  (0x99), a
    ; /TESTER
    
    
    ld a, (TIMER)                  ; handle the blink
    inc a
    cp 25                          ; half a second.
    jr z, TextOn
    cp 50
    jp z, TextOff
AfterTxt:
    ld (TIMER), a
    
    call GetActionKeys
    bit 0, a                       ; bit 0 = spacebar
    jr nz, SCROLL
    
    
    ; TESTER
    ; ld   a, 0x00         ; Kleur 1 = Zwart
    ; out  (0x99), a       ; (Dubbele out voor timing stabiliteit)
    ; ld   a, 128 + 7
    ; out  (0x99), a
    ; /TESTER
    
    jr BlinkLoop
    
SCROLL:
    ld HL, HMMVBlink
    call Waitvdp
    call HMMV                      ; clean visible sentence
    
    ld HL, HMMVBlink               ; update HMMV block
    xor a
    ld (HL), a
    inc hl
    ld (HL), a                     ; dx 0
    inc hl
    ld a, 230
    ld (hl), a
    inc hl
    xor a
    ld (hl), a                     ; dy 230
    
    ld HL, HMMVBlink
    call Waitvdp
    call HMMV                      ; clean invisible sentence
    
    call Waitvdp
    call ScrollUp8
    ret
    
TextOn:
    ld HL, HMMMBlink
    call HMMM
    ld a, 25                       ; continue timer
    jp AfterTxt
    
TextOff:
    ld HL, HMMVBLink
    call HMMV
    xor a                          ; reset timer.
    jp AfterTxt
    
WriteText:
    ld HL, LOGOTEXT                ; location to X (1),Y (1), text (bytes)
    ld b, 20                       ; length of text
    call WriteString8
    ret
    

    .section .data
    
LOGOTEXT:
    .byte 0, 243, "Press space to start" ; X, Y, tekst    (y = onderaan tekst)
HMMMBlink:
    .word 0,230                    ; sx,sy
    .word 60, 180                  ; dx,dy
    .word 160, 14                  ; mx, my
    .byte 0x00, 0x00, 0xD0         ; color, arg, command
HMMVBlink:
    .word 60, 180                  ; dx,dy
    .word 160, 14                  ; mx, my
    .byte 0x00, 0x00, 0xC0         ; color (black), arg, command
    