;; ==[ Azul5StartGame ]==================================================
;;
    .section .text
    .global Azul5StartGame

Azul5StartGame:
    ld HL, SCORE                   ; Reset the score
    ld (HL), 0
    inc HL
    ld (HL),0
    call PrintScoreP1              ; print initial score
    call PrintScoreP2

    call ResetBag                  ; Fill the bag with 100 tiles, 20 each.
    CALL EnableSprites16           ; Enables sprites for screen5, with 16x16 size. tables on 7400/7600/7800
    call LoadSprites

    call FillFactory               ; Draw random 20 tiles and place on factory.

    ld D, 48                       ; 1st factory tile
    ld E, 44
    CALL ShowSelector
    ret

FillFactory:
    ld hl, FACTORYPOSITIONS        ; destinations for tiles, go through 1 by 1
    ld b, 20                       ; factory needs 20 tiles
.loop:
    push bc
    push hl
    call TakeATile                 ; a = random tile-type from the bag

    pop hl                         ; factory positions
    ld d, (HL)                     ; d=dx
    inc hl
    ld e, (HL)                     ; e=dy
    inc hl
    push hl
    LD c, a                        ; c = tiletype

    push bc
    push de
    call SpriteFromBag             ; C = tile type, DE= XY of dest.
    pop de
    pop bc
    call ShowTile                  ; tile graphic  C = type, DE = location,

    pop hl
    pop bc
    djnz .loop
    ret



SpriteFromBag:                     ; C = tile type, DE = XY of dest factory
    LD A, D                        ; calculate dX and dY in HL
    SUB 0x08                        ; 0x08 = X of bag
    srl A
    srl a
    srl a                          ; a= a/ 8
    LD H, A                        ; 0x23 = Y of bag
    LD A, E
    SUB 0x23
    srl A
    srl a
    srl a                          ; a= a/ 8
    LD L, A                        ; HL = now dxdy in 8 steps.


    ld DE, 0x0823
    ld b, 8
.loop1:                             ; HL = dxy, BC = loop+type, DE = xy
    push bc
    push de
    push hl

    ld b, c
    ld c, 0
    call ShowTileSprite            ; DE = xy, B = type, C = spritenr
    ld c, 2
    call LastSprite16              ; C = spritenr
    ld b, 2
    call SmallWait

    pop de                         ; we exchange EX with BC on purpose
    pop hl
    ADD HL, DE                     ; move the sprite
    EX DE, HL

    pop bc
    djnz .loop1

    ld c, 0                        ; remove the sprite
    call LastSprite16
    ret

ResetBag:                          ; add all tiles to the bag again.
    ld HL, TILESINBAG
    ld b, 5
.loop2:
    ld (HL), 20
    inc HL
    djnz .loop2
    ret

LoadSPrites:
    ; --- 1. SPT: Vorm (7800h) ---
    ld   hl, 0x7800
    call SetVramWrite
    ld   hl, SpritePatterns
    ld   b, 255                    ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1a:
    ld a, (hl)
    inc hl
    out (VDPD), a
    djnz .l1a
    ld   b, 448-255                ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1b:
    ld a, (hl)
    inc hl
    out (VDPD), a
    djnz .l1b
    ret

    .section .data

SCORE:
    .byte 0x00, 0x00                    ; Score of player1, player2 in BCD format

TILESX:
    .byte 0, 10, 20, 30, 40           ; Blue, yellow, red, black, white tile
    .byte 50                          ; 1st player / empty
    .byte 110, 120                    ; factory replacements
NUMBERSX:
    .byte 60, 70, 80, 90, 100         ; 0,1,2,3,4 the NUMBERSY is BELOW or BELOW+10
    .byte 60, 70, 80, 90, 100         ; 5,6,7,8,9


;;;;;; TODO ;;;;;;

TILESINFACTORY:                    ; count of tiletype per factory.
    .byte 00,00,00,00,00              ; factory 1
    .byte 00,00,00,00,00              ; factory 2
    .byte 00,00,00,00,00              ; factory 3
    .byte 00,00,00,00,00              ; factory 4
    .byte 00,00,00,00,00              ; factory 5
TILESONTABLE:
    .byte 00,00,00,00,00              ; count of tiletypes on table
FIRSTPLAYERONTABLE:
    .byte 00                          ; is 1stplayer still on table?
