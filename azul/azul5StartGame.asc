;; ==[ Azul5StartGame ]==================================================
;;

Azul5StartGame:
    ld HL, SCORE             ; Reset the score
    ld (HL), 0
    inc HL
    ld (HL),0
    call PrintScoreP1        ; print initial score
    call PrintScoreP2

    call ResetBag            ; Fill the bag with 100 tiles, 20 each.
    CALL EnableSprites16     ; Enables sprites for screen5, with 16x16 size. tables on 7400/7600/7800
    call LoadSprites

    call FillFactory         ; draw random 20 tiles and place on factory.
    ret


FillFactory:
    ld hl, FACTORYPOSITIONS  ; destinations for tiles, go through 1 by 1
    ld b, 20                 ; factory needs 20 tiles
.loop:
    push bc
    push hl
    call TakeATile           ; a = random tile-type from the bag

    ld HL, TILESX            ; tile graphic
    LD c, a                  ; c = tiletype
    LD b, 0
    ADD HL, bc               ; HL = HL + A, HL points to right tile
    ld a, (HL)               ; A = SX

    pop hl                   ; factory positions
    ld d, (HL)               ; d=dx
    inc hl
    ld e, (HL)               ; e=dy
    inc hl
    push hl

    ld HL, TILEHMMM
    ld (HL), a               ; sx
    inc hl
    inc hl                   ; sy
    inc hl

    inc hl
    ld (HL), d               ; dx
    inc hl
    inc hl
    ld (HL), e               ; dy

    ; hmmm header filled now anymate
    ; C = tile type, DE= XY of dest.
   ; inc c
    call SpriteFromBag

    ld HL, TILEHMMM          ; put tile on screen
    call Waitvdp
    CALL HMMM                ; VRAM to VRAM transfer. <HL> : Address of header

    pop hl
    pop bc
    djnz .loop
    ret

SpriteFromBag:               ; C = tile type, DE = XY of dest factory
    

    LD A, D                  ; calculate dX and dY in HL
    SUB $08                  ; $08 = X of bag
    srl A
    srl a
    srl a                    ; a= a/ 8
    LD H, A                  ; $23 = Y of bag
    LD A, E
    SUB $23
    srl A
    srl a
    srl a                    ; a= a/ 8
    LD L, A                  ; HL = now dxdy in 8 steps.


    ld DE, $0823
    ld b, 8
.loop:
    push bc
    LD B, C
    push de
    push hl
    ld c, 0
    call ShowTileSprite      ; DE = xy, B = type, C = spritenr
    ld c, 2
    call LastSprite          ; C = spritenr

    ld b, 2
    call SmallWait

    pop hl
    pop de
    pop bc
    EX DE, HL
    ADD HL, DE
    EX DE, HL

    djnz .loop

    ld c, 0
    call LastSprite
    ret



ResetBag:                    ; add all tiles to the bag again.
    ld HL, TILESINBAG
    ld b, 5
.loop:
    ld (HL), 20
    inc HL
    djnz .loop
    ret

TakeATile:                   ; Take a tile from the bag = A = type. (0-4 for blue, yellow, red, black, white)

    ld HL, TILESINBAG        ; Count total tiles left.
    ld b, 5
    ld a, 0
.loop:
    ld c, (HL)
    inc HL
    add a, c
    djnz .loop              
    ld e, a                 ; E = total
.rnd:
    ld a,r                  ; take a random nr
    ld b,a
    ld a,(RND)
    xor b
    ld (RND),a

    cp e
    jr NC, .rnd             ; the random nr was too big
                            ; a is an in-range number, now find its color/type
    ld HL, TILESINBAG
    ld b, 5
.typeloop:    
    ld c, (HL)
    cp c                     ; is it a match?
    jr C, .found
    inc HL
    sub a, c                 ; remve the stack of this color, and check next.
    djnz .typeloop

.found:                     ; b = the stack (1-5) HL point address
                            ; 5 = blue, 4= yellow, 3= red 2 = black 1 = white
    ld a, (HL)
    or a
    jp z, .rnd               ; pile is empty, try again.
    dec a
    ld (HL), a               ; remove one from pile
    ld a, 5
    sub a, b                 ; a = 0-4 for the right type.
    ret
    
LoadSPrites:
    ; --- 1. SPT: Vorm (7800h) ---
    ld   hl, $7800
    call SetVramWrite
    ld   hl, SpritePatterns
    ld   b, 255              ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1a:
    ld a, (hl)
    inc hl
    out ($98), a
    djnz .l1a
    ld   b, 448-255          ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1b:
    ld a, (hl)
    inc hl
    out ($98), a
    djnz .l1b
    ret

ShowTileSprite:              ; show a tile (2 sprites, same location)
                             ; DE = xy, B = type, C = spritenr
    push BC                  ; Needed at color table

    ld a, b                  ; A = type

    ld hl, $7600             ; do SAT
    LD B, 0                  ; point HL to right vram address
    SLA C                    ; for sat its 4 bytes per sprite, we use 2, so spritenr*8
    RL B
    SLA C
    RL B
    SLA C
    RL B                     ; bc = bc*8
    ADD HL, BC               ; HL = HL + BC
    
    ld c, a                  ; 4 patterns per sprite, 2 sprites per type, so type*8 is needed
    SLA C                    ; for sat its 4 bytes per sprite, we use 2, so spritenr*8
    SLA C
    SLA C                    ; c = c*8
    
    call SetVramWrite
    ld   a, E
    out ($98), a             ; E = Y
    ld   a, D
    out ($98), a             ; D = X
    ld   a, C
    out ($98), a             ; C = Pattern
    ld   a, $40
    out ($98), a             ; CC=1 (Gebruik SCT), Kleur=0

    inc c
    inc c
    inc c
    inc c                    ; next pattern

    ld   a, E
    out ($98), a             ; E=Y
    ld   a, D
    out ($98), a             ; D=X
    ld   a, C
    out ($98), a             ; C=Pattern
    ld   a, $40
    out ($98), a             ; CC=1 (Gebruik SCT), Kleur=0


    pop bc                   ; now load the colortable for this sprite
                             ; DE = xy, B = type, C = spritenr
                             ; 16 colors per sprit, 2 sprites so c*32
    ld a, b                  ; a = type
    ld h, 0
    ld l, c                  ; hl = c
    ADD HL, HL               ; HL * 2
    ADD HL, HL               ; HL * 4
    ADD HL, HL               ; HL * 8
    ADD HL, HL               ; HL * 16
    ADD HL, HL               ; HL * 32
    LD B, H                  ; BC = HL
    LD C, L

    ld   hl, $7400
    ADD HL, BC               ; HL = HL + BC
    call SetVramWrite

    ld   hl, SpriteColors    ; colors are 1 byte per sprite, so type*2
    add a, a
    ld b, 0
    ld c, a
    add hl, bc

    ld a, (hl)
    ld   b, 16               ; 16 lijnen kleur
.l2a:
    out ($98), a
    djnz .l2a

    inc hl
    ld a, (hl)
    ld   b, 16               ; 16 lijnen kleur
.l2b:
    out ($98), a
    djnz .l2b
    ret

LastSprite:                  ; close the spritearray C = spritenr
    ld   hl, $7600

    LD B, 0                  ; point HL to right vram address
    SLA C
    RL B
    SLA C
    RL B                     ; c = c*4
    ADD HL, BC               ; HL = HL + BC
    call SetVramWrite
    ld   a, $D8              ; Y=$D8 = terminator
    out ($98), a
    ret



; ==[ Data ]====================================================
    
SCORE:
    db $00, $00              ; Score of player1, player2 in BCD format
TILESINBAG:
    db 20,20,20,20,20        ; 20 blue, 20 yellow, 20 red, 20 black, 20 white tiles.
RND:                         
    db 42                    ; the last random nr
FACTORYPOSITIONS:
    db 48,45                 ; x,y for every tile on a factory (20 places)
    db 48+12, 45             ; 1 2
    db 48, 45+12             ; 3 4 pattern
    db 48+12, 45+12

    db 11,85
    db 11+12,85
    db 11,85+12
    db 11+12,85+12

    db 91,85
    db 91+12,85
    db 91,85+12
    db 91+12,85+12

    db 11,128
    db 11+12,128
    db 11,128+12
    db 11+12,128+12
    
    db 91,128
    db 91+12,128
    db 91,128+12
    db 91+12,128+12
    
TILESX:
    db 0, 10, 20, 30, 40     ; Blue, yellow, red, black, white tile
    db 50                    ; 1st player / empty
    db 110, 120              ; factory replacements
NUMBERSX:
    db 60, 70, 80, 90, 100   ; 0,1,2,3,4 the NUMBERSY is BELOW or BELOW+10
    db 60, 70, 80, 90, 100   ; 5,6,7,8,9

TILEHMMM:
    db $00, $00              ; 2sx
    dw BELOW                 ; 2sy
    db $00,$00,$00,$00       ; dx dy
    dw 10, 10                ; mx, my
    db $0, $0, $D0           ; 1CLR,1ARG,1CMD

	include "SpriteData.as"
