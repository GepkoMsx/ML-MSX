;; ==[ Azul5StartGame ]==================================================
;;
    .section .text
    .global Azul5StartGame

    .include "Macros.asc"

Azul5StartGame:
    ScoreReset
    call ScorePrintP1              ; print initial score
    call ScorePrintP2

    BagReset                       ; Fill the bag with 100 tiles, 20 each.
    EnableSprites16                ; Enables sprites for screen5, with 16x16 size. tables on 7400/7600/7800
    
    call LoadSprites
    call FactoryFill               ; Draw random 20 tiles and place on factory.

    ld D, 48                       ; 1st factory tile
    ld E, 44
    CALL SelectorShow
    ret


LoadSprites:
    ; --- 1. SPT: Vorm (7800h) ---
    ld   hl, 0x7800
    SetVramWrite
    ld   hl, SpritePatterns
    ld   b, 255                    ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1a:
    ld a, (hl)
    inc hl
    out (VDPD), a
    djnz .l1a
    ld   b, 448-255                ; 16x16 sprite  x2 x7  (2 sprites per tile, 7 tiles) = 448, so 2 loops
.l1b:
    ld a, (hl)
    inc hl
    out (VDPD), a
    djnz .l1b
    ret

    .section .data
    .global TILESX, NUMBERSX, TILESINFACTORY, TILESONTABLE, FIRSTPLAYERONTABLE


TILESX:
    .byte 0, 10, 20, 30, 40        ; Blue, yellow, red, black, white tile
    .byte 50                       ; 1st player / empty
    .byte 110, 120                 ; factory replacements
NUMBERSX:
    .byte 60, 70, 80, 90, 100      ; 0,1,2,3,4 the NUMBERSY is BELOW or BELOW+10
    .byte 60, 70, 80, 90, 100      ; 5,6,7,8,9

TILESINFACTORY:                    ; tiletype per factoryspot. (FF = empty, 0-4 for blue, yellow, red, black, white)
    .byte 0,0,0,0                  ; factory 1
    .byte 0,0,0,0                  ; factory 2
    .byte 0,0,0,0                  ; factory 3
    .byte 0,0,0,0                  ; factory 4
    .byte 0,0,0,0                  ; factory 5
TILESONTABLE:
    .byte 0,0,0,0,0                ; count of tiletypes on table
FIRSTPLAYERONTABLE:
    .byte 00                       ; is 1stplayer still on table?
