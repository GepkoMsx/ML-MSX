    .section .data
    .global FACTORYPOSITIONS, TILESONTABLEPOSITIONS, TILESWALL1POSITIONS, TILESWALL2POSITIONS

FACTORYPOSITIONS:
    .byte 48,45                    ; x,y for every tile on a factory (20 places)
    .byte 48+12, 45                ; 1 2
    .byte 48, 45+12                ; 3 4 pattern
    .byte 48+12, 45+12

    .byte 11,84
    .byte 11+12,84
    .byte 11,84+12
    .byte 11+12,84+12

    .byte 91,84
    .byte 91+12,84
    .byte 91,84+12
    .byte 91+12,84+12

    .byte 11,127
    .byte 11+12,127
    .byte 11,127+12
    .byte 11+12,127+12
    
    .byte 91,127
    .byte 91+12,127
    .byte 91,127+12
    .byte 91+12,127+12

TILESONTABLEPOSITIONS:             ; 6 tiles in a column in the middle
    .byte 48,84                    ; the 5 colors and start-tile.
    .byte 48,84+12                 ; next to it, a number counting the amount.
    .byte 48,84+24
    .byte 48,84+36
    .byte 48,84+48
    .byte 48+6,84+60               ; starttile.

TILESWALL1POSITIONS:               ; 5 right most tiles at the wall for player 1
    .byte 00,00                    ; TODO!
    .byte 00,00
    .byte 00,00
    .byte 00,00
    .byte 00,00

TILESWALL2POSITIONS:               ; 5 right most tiles at the wall for player 2
    .byte 00,00                    ; TODO!
    .byte 00,00
    .byte 00,00
    .byte 00,00
    .byte 00,00

