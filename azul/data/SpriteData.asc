; Spritedata. The SpritePatterns and SpriteColors
; 2 sprites per tile
; Patternorder: 0 = blue, 8 = yellow, 16 = red, 24 = black 32 = white, 40 = 1stplayer (3sprite)
;               56 = selector (1 sprite)

    .section .data
    .global SpritePatterns, SpriteColors

SpritePatterns:
    ; BLUE
    .byte 0b11111111, 0b10000000, 0b10111111, 0b10100001, 0b10101101 ; 1 left blue
    .byte 0b10101101, 0b10100001, 0b10111111, 0b10000000, 0b11111111
    .byte 0,0,0,0,0,0
    .byte 0b11000000, 0b01000000, 0b01000000, 0b01000000, 0b01000000 ; 1 right
    .byte 0b01000000, 0b01000000, 0b01000000, 0b01000000, 0b11000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b01111111, 0b01000000, 0b01011110, 0b01010010 ; 2 left light blue
    .byte 0b01010010, 0b01011110, 0b01000000, 0b01111111, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b10000000, 0b10000000, 0b10000000 ; 2 right
    .byte 0b10000000, 0b10000000, 0b10000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0

    ; YELLOW
    .byte 0b11111111, 0b10100001, 0b11011110, 0b10101101, 0b10110011 ; 1 left yellow
    .byte 0b10110011, 0b10101101, 0b11011110, 0b10100001, 0b11111111
    .byte 0,0,0,0,0,0
    .byte 0b11000000, 0b01000000, 0b11000000, 0b01000000, 0b01000000 ; 1 right
    .byte 0b01000000, 0b01000000, 0b11000000, 0b01000000, 0b11000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b01011110, 0b00100001, 0b01010010, 0b01001100 ; 2 left red
    .byte 0b01001100, 0b01010010, 0b00100001, 0b01011110, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b00000000, 0b10000000, 0b10000000 ; 2 right
    .byte 0b10000000, 0b10000000, 0b00000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0

    ; RED
    .byte 0b11111111, 0b10010010, 0b11110011, 0b11110011, 0b10010010 ; 1 left red
    .byte 0b10010010, 0b11110011, 0b11110011, 0b10010010, 0b11111111
    .byte 0,0,0,0,0,0
    .byte 0b11000000, 0b01000000, 0b11000000, 0b11000000, 0b01000000 ; 1 right
    .byte 0b01000000, 0b11000000, 0b11000000, 0b01000000, 0b11000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b01101101, 0b00001100, 0b00001100, 0b01101101 ; 2 left pink
    .byte 0b01101101, 0b00001100, 0b00001100, 0b01101101, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b00000000, 0b00000000, 0b10000000 ; 2 right
    .byte 0b10000000, 0b00000000, 0b00000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0

    ; BLACK
    .byte 0b11111111, 0b10110011, 0b11011110, 0b11101101, 0b10111111 ; 1 LEFT black
    .byte 0b10111111, 0b11101101, 0b11011110, 0b10110011, 0b11111111
    .byte 0,0,0,0,0,0
    .byte 0b11000000, 0b01000000, 0b11000000, 0b11000000, 0b01000000 ; 1 RIGHT
    .byte 0b01000000, 0b11000000, 0b11000000, 0b01000000, 0b11000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b01001100, 0b00100001, 0b00010010, 0b01000000 ; 2 LEFT cyan
    .byte 0b01000000, 0b00010010, 0b00100001, 0b01001100, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b00000000, 0b00000000, 0b10000000 ; 2 RIGHT
    .byte 0b10000000, 0b00000000, 0b00000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0
    
    ; WHITE
    .byte 0b11111111, 0b10110011, 0b11010010, 0b11111111, 0b10010010 ; 1 left white
    .byte 0b10010010, 0b11111111, 0b11010010, 0b10110011, 0b11111111
    .byte 0,0,0,0,0,0
    .byte 0b11000000, 0b01000000, 0b11000000, 0b11000000, 0b01000000 ; 1 right
    .byte 0b01000000, 0b11000000, 0b11000000, 0b01000000, 0b11000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b01001100, 0b00101101, 0b00000000, 0b01101101 ; 2 left cyan
    .byte 0b01101101, 0b00000000, 0b00101101, 0b01001100, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b00000000, 0b00000000, 0b10000000 ; 2 right
    .byte 0b10000000, 0b00000000, 0b00000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0

    ; 1stplayer
    .byte 0b00111111, 0b01000000, 0b01000100, 0b01001100, 0b10000100 ; 1 left dark blue
    .byte 0b10000100, 0b01000100, 0b01001110, 0b01000000, 0b00111111
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b10000000, 0b10000000, 0b10000000, 0b01000000 ; 1 right
    .byte 0b01000000, 0b10000000, 0b10000000, 0b10000000, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b00000000, 0b00001000, 0b00010000, 0b00001000 ; 2 left light blue
    .byte 0b00001000, 0b00001000, 0b00010000, 0b00000000, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b00000000, 0b00000000, 0b00000000, 0b00000000 ; 2 right
    .byte 0b00000000, 0b00000000, 0b00000000, 0b00000000, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b00111111, 0b00110011, 0b00100011, 0b01110011 ; 3 left white
    .byte 0b01110011, 0b00110011, 0b00100001, 0b00111111, 0b00000000
    .byte 0,0,0,0,0,0
    .byte 0b00000000, 0b00000000, 0b00000000, 0b00000000, 0b10000000 ; 3 right
    .byte 0b10000000, 0b00000000, 0b00000000, 0b00000000, 0b00000000
    .byte 0,0,0,0,0,0
    
    ; selector 12x12 square
    .byte 0b11111111, 0b10000000, 0b10000000, 0b10000000, 0b10000000 ; 1 left Green
    .byte 0b10000000, 0b10000000, 0b10000000, 0b10000000, 0b10000000
    .byte 0b10000000, 0b11111111, 0,0,0,0
    .byte 0b11110000, 0b00010000, 0b00010000, 0b00010000, 0b00010000 ; 1 right
    .byte 0b00010000, 0b00010000, 0b00010000, 0b00010000, 0b00010000
    .byte 0b00010000, 0b11110000, 0,0,0,0
    
SpriteColors:                      ; repeat all 16x
    .byte 0x24, 0x63               ; blue
    .byte 0x27, 0x66               ; yellow
    .byte 0x26, 0x62               ; red
    .byte 0x29, 0x6A               ; black
    .byte 0x2D, 0x6A               ; white
    .byte 0x21, 0x63, 0x6D         ; 1st player
    .byte 0x2F                     ; selector (+13)
