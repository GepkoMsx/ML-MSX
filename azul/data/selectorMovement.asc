
    .section .data
    .global SELECTORMOVEMENT
    
SELECTORMOVEMENT:

; first the factories, same order as in factoryPositions
; every position has 4 bytes pointing left, right, up, down
; not possible movements are 0xFF. Layout:

;      00  01
;      02  03
;
; 04 05  14  08 09
; 06 07  15  0A 0B
;        16
; 0C 0D  17  10 11
; 0E 0F  18  12 13
;

    .byte 0xFF, 0x01, 0xFF, 0x02          ; 0x00  First Factory
    .byte 0x00, 0xFF, 0xFF, 0x03          ; 0x01
    .byte 0xFF, 0x03, 0x00, 0x05          ; 0x02
    .byte 0x02, 0xFF, 0x01, 0x08          ; 0x03
    
    .byte 0xFF, 0x05, 0xFF, 0x06          ; 0x04  Second Factory
    .byte 0x04, 0x14, 0x02, 0x07          ; 0x05
    .byte 0xFF, 0x07, 0x04, 0x0C          ; 0x06
    .byte 0x06, 0x15, 0x05, 0x0D          ; 0x07
    
    .byte 0x14, 0x09, 0x03, 0x0A          ; 0x08  Third Factory
    .byte 0x08, 0xFF, 0xFF, 0x0B          ; 0x09
    .byte 0x15, 0x0B, 0x08, 0x10          ; 0x0A
    .byte 0x0A, 0xFF, 0x09, 0x11          ; 0x0B
    
    .byte 0xFF, 0x0D, 0x06, 0x0E          ; 0x0C  Fourth factory
    .byte 0x0C, 0x17, 0x07, 0x0F          ; 0x0D
    .byte 0xFF, 0x0F, 0x0C, 0xFF          ; 0x0E
    .byte 0x0E, 0x18, 0x0D, 0xFF          ; 0x0F
    
    .byte 0x17, 0x11, 0x0A, 0x12          ; 0x10  Fifth factory
    .byte 0x10, 0xFF, 0x0B, 0x13          ; 0x11
    .byte 0x18, 0x13, 0x10, 0xFF          ; 0x12
    .byte 0x12, 0xFF, 0x11, 0xFF          ; 0x13
    
    .byte 0x05, 0x08, 0xFF, 0x15          ; 0x14  Tiles on table
    .byte 0x07, 0x0A, 0x14, 0x16          ; 0x15
    .byte 0xFF, 0xFF, 0x15, 0x17          ; 0x16
    .byte 0x0D, 0x10, 0x16, 0x18          ; 0x17
    .byte 0x0F, 0x12, 0x17, 0xFF          ; 0x18
    