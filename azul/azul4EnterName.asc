;; ==[ AZUL4EnterName ]==================================================
;;
    
; Ask players to enter the name + enterlogic.
Azul4EnterName:
    ld A, 0                  ; Enter name for palyer 1or2? (0-1)
    call EnterName
    
    ld HL, NAAM1             ; location to X (1),Y (1), text (bytes)
    ld bc, $0709             ; b: length of text c: color black
    call WriteString8
    
    ; for now, the computer
    ld HL, NAAM2             ; location to X (1),Y (1), text (bytes)
    ld bc, $0709             ; b: length of text c: color black
    call WriteString8
    
    ; can we now start??
    ret
    
;; CALL EnterName
;; input: A = PLayer (0,1)
EnterName:
    ld HL, CURPOS            ; set player in curpos
    ld b, 0                  ; and position in string = 0
    or a
    jr NZ, .p2bit
    jr .p2bitcont
.p2bit:
    set 7, b
.p2bitcont:
    ld (HL), b
    
    ld HL, TXTNAMEQ1+9       ; update textmessage for player
    add a, '1'
    ld (HL), a
    
    ld a, 7
    ld (LETTERWIDTH), a
    ld HL, TXTNAMEQ1         ; print Question line 1.
    ld bc, $0809             ; 8 characters, color 9
    call WriteString8
    
    ld HL, TXTNAMEQ2         ; print Question line 1.
    ld bc, $1009             ; 16 character, color 9
    call WriteString8
    ld a, 8
    ld (LETTERWIDTH), a
    
    call GetXY               ; DE = xy, HL = address of letter (pos = 0 now)
    ld b,8                   ; clear name in memory
.ClearNameLoop:
    ld (HL), ' '
    inc HL
    DJNZ .ClearNameLoop
    
    xor a
    ld (TIMER), a
EnterNameLoopStart:
    xor a                    ; Kijk naar Status register 0
    out ($99), a             ; waarde 0
    ld a, $8F                ; $8F = Register 15 (Status Pointer)
    out ($99), a             ; de VDP staat nu op SR#0
.Waitloop:                   ; Wait on V-Blank (Synchronize)
    in a,($99)               ; Wacht nu tot hij weer 0 is
    rlca
    jp nc, .Waitloop
    
.TimerLogic:
    ld a, (TIMER)            ; keep track of timer
    inc a
    cp 25                    ; blink cursor
    jp Z, .BlinkOn
    cp 50
    call Z, .BlinkOff
.AfterBlink:
    ld (TIMER), a
    
    CALL GetFirstKey         ; Returns A: Key pressed, or 0 for no key
    cp 'n'                   ; Enter/Return
    jp z, .KeyEnter
    cp 'b'                   ; BS
    jp z, .KeyBS
                               ; is it a regular letter?
    cp 65                    ; Is A < 65?  (a=0 : no key)
    jr c, EnterNameLoopStart ; Ja, dus te laag.
    cp 91                    ; Is A < 91? (91 is de eerste waarde NA 'Z')
    jr nc, EnterNameLoopStart ; Nee (dus A >= 91), te hoog.
    
.ItsLetter:
    ld b, a                  ; b = letter
    ld HL, CURPOS            ; check maxlength (7)
    ld a, (HL)
    and $7F
    cp 7
    jr Z, EnterNameLoopStart ; we're full, wait on enter or bs
    ld c, a                  ; c = pos
    push bc
    
    call .BlinkOff           ; make sure the blinker is not here
    call GetXY               ; HL = addres, DE = XY
    
    pop bc                   ; b = letter, c = pos
    ld a, c
    or a                     ; first pos = capital

    ld a, b
    jr Z, .StoreLetter
    or %00100000             ; make lowercase a = letter
.StoreLetter:
    ld (HL), a               ; store letter in RAM
    
    ld b, 9                  ; b = color black, DE = location, a = letter
    CALL WriteLetter8        ; Writes a letter on screen. <A>: letter, <B>: color, <DE>: XY coord on screen.
    
    ld HL, CURPOS            ; advance to next location
    inc (HL)
    
    ld DE, 1                 ; debounce keyboard
    CALL Wait                ; Wait <DE> * 0.1 secs.
    
    jr EnterNameLoopStart
    
    
    
.BlinkOff:                   ; call
    call GetXY
    ld HL, CLEARLETTER
    ld (HL), d
    inc hl
    inc hl
    ld a, e                  ; letters XY is at bottom of letter, HMMV top.
    sub 12
    ld (hl), a
    dec hl
    dec hl
    call HMMV
    
    xor a                    ; 1 sec has past, reset.
    ret
    
.BlinkOn:                    ; jump
    call GetXY
    ld a, '|'
    ld b, 9                  ; black
    CALL WriteLetter8        ; Writes a letter on screen. <A>: letter, <B>: color, <DE>: XY coord on screen.
    ld a, 25
    jp .AfterBlink
    
.KeyBS:
    call .BlinkOff
    
    ld HL, CURPOS            ; Check if there is a letter to remove.
    ld a, (HL)
    and $7F
    or a
    jp Z, EnterNameLoopStart
    
    dec a                    ; erase
    ld (HL), a
    call .BlinkOff
    
    ld DE, 1                 ; debounce keyboard
    call Wait
    
    jp EnterNameLoopStart
    
.KeyEnter:                   ; READY with name!
    call Waitvdp             ; remove text question
    ld HL, CLEARTXT
    call HMMV
    call Waitvdp
    ret
    
GetXY:
    ld a, (CURPOS)
    or a
    jp M, .GetXY2            ; player 2
    ld HL, NAAM1
    jr .GetXYnext
.GetXY2:
    ld HL, NAAM2
    
.GetXYnext:
    ld d, (HL)
    inc HL
    ld e, (HL)
    inc HL
    
    and $7F                  ; remove player sign
    ld b, 0
    ld c, a
    add hl, bc               ; HL points to letter
    
                             ; MAX 36 letters! (kan toch niet voorbij scherm!)
    ld b, a                  ; Bewaar de originele waarde in b
    add a, a                 ; A * 2
    add a, a                 ; A * 4
    add a, a                 ; A * 8
    
    add d
    ld d, a                  ; DE point to right XY
    ret
    

    
; ==[ Data ]====================================================
    
NAAM1:
    db $9E, $11, "Gepko   "  ; X, Y, tekst(9)    (y = onderaan tekst)
NAAM2:
    db $9E, $7C, "PC guy  "  ; X, Y, tekst(9)    (y = onderaan tekst)
CURPOS:
    db $00                   ; bit 7: Player (0-1) L-nibbe: Position in NAAM-string
TXTNAMEQ1:
    db 0, 180, "Player 1"
TXTNAMEQ2:
    db 0, 180+12, "What's your name"
CLEARTXT:
    dw 0, 180-12, 126, 40    ; HMMV header for clearing message area
    db 0, 0, $C0             ; 3 lines of 17 characters
CLEARLETTER:
    dw 0, 0, 8, 12           ; HMMV header for clearing message area
    db $BB, 0, $C0           ; 1 character
    