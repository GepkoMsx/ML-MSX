;; ==[ AZUL3Playfield ]==================================================
;;
;; show the playfield
;; fabriek to the left, 2 boards to the right
;;
    
    .section .text
    .global  Azul3Playfield, BELOW

    .equ picbord1, 0x4000
    .equ pictiles, 0x5100
    .equ picfabriek, 0x5600
    .equ BELOW, 0xD5

    .include "Macros.asc"
    
; Draws the playfield
Azul3Playfield:
    SetVDP 23, 0                   ; Reset the scrolling
    SetVDP 7,0                     ; border color 0
    
    SetScreen 5, off
    
    ld HL, COLORMAP
    SetPalette16
    call Waitvdp
    
    VdpCopy HMMV, CLEARSCREEN      ; make screen clean with hmmv page0
    call Waitvdp
    
    VdpCopy HMMC, HMMCFabriek      ; Draw factory, send color data by hand
    ld HL, picfabriek
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 0
    
    VdpCopy HMMC, HMMCBord         ; Draw board player 1
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 212/2
    
    VdpCopy HMMC, HMMCBord         ; Draw board player 2
    ld HL, picbord1
    call RLESendVDP
    
    VdpCopy HMMC, HMMCTiles        ; Prepare tiles
    ld HL, pictiles
    call RLESendVDP
    
    SetVDP 1, 0x40                 ; Screen on
    ret

    .section .data
    
HMMCFabriek:
    .word 0x0000, 0x0000           ; dx, dy
    .word 0x0080, 0x009F           ; nx, ny
    .byte 0x00, 0x00               ; color, arg

HMMCBord:
    .word 0x007E, 0x0000           ; dx, dy
    .word 0x0082, 0x006A           ; nx, ny
    .byte 0x00, 0x00               ; color, arg

HMMCTiles:
    .word 0x0000, BELOW            ; dx, dy
    .word 0x0082, 0x0014           ; nx, ny
    .byte 0x44, 0x00               ; color, arg
    
CLEARSCREEN:                       ; HMMV header voor LEEG scherm page0, color 0
    .word 0x0000, 0x0000           ; dx, dy
    .word 0x0100, 0x0100           ; nx, ny
    .byte 0x00, 0x00               ; color, arg
    
    

    
    
    