;; ==[ AZUL3Playfield ]==================================================
;;
;; show the playfield
;; fabriek to the left, 2 boards to the right
;;
    
picbord1    equ $4000
pictiles    equ $5100
picfabriek  equ $5600
BELOW       equ $D5
    
; Draws the playfield
Azul3Playfield:
    xor a                    ; Reset the scrolling
    out ($99), a
    ld a, $97                ; Register 23
    out ($99), a
    call Waitvdp
    
    ld a, 0
    call Border
    
    ld HL, Screen5_Table
    call screen              ; screen 5 not visible
    call Waitvdp
    
    ld HL, COLORMAP
    call SetPalette16
    call Waitvdp
    
    ld HL, CLEARSCREEN       ; make screen clean with hmmv page0
    call HMMV
    call Waitvdp
    
    
    ld HL, HMMCFabriek       ; Draw factory
    call HMMCNoData
    ld HL, picfabriek
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 0
    
    ld HL, HMMCBord          ; Draw board player 1
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 212/2
    
    ld HL, HMMCBord          ; Draw board player 2
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCTiles         ; Prepare tiles
    call HMMCNoData
    ld HL, pictiles
    call RLESendVDP
    
    
    ld a, $40                ; Screen on
    out ($99), a
    ld a, $81                ; Schrijf naar Register #1
    out ($99), a
    
    ret
    
; ==[ Data ]====================================================
HMMCFabriek:
    dw $0000, $0000          ; dx, dy
    dw $0080, $009F          ; nx, ny
    db $00, $00, $F0         ; color, arg, command
HMMCBord:
    dw $007e, $0000          ; dx, dy
    dw $0082, $006A          ; nx, ny
    db $00, $00, $F0         ; color, arg, command
HMMCTiles:
    dw $0000, BELOW          ; dx, dy
    dw $007A, $0017          ; nx, ny
    db $44, $00, $F0         ; color, arg, command
    
CLEARSCREEN:
    dw 0, 0, 256, 256        ; HMMV header voor LEEG scherm page0, color 0
    db 0, 0, $C0
    
COLORMAP:                    ; RB 0G
    db $76, $07              ; Color 0   Sand    (background)
    db $02, $01              ; Color 1   DarkBlue
    db $74, $04              ; Color 2   Pink
    db $47, $06              ; Color 3   LightBlue
    db $05, $04              ; Color 4   Blue
    db $41, $02              ; Color 5   Brown
    db $71, $01              ; Color 6   Red
    db $71, $05              ; Color 7   Gold
    db $55, $05              ; Color 8   Gray
    db $00, $00              ; Color 9   Black
    db $26, $06              ; Color 10  Cyan
    db $63, $05              ; Color 11  LightBrown
    db $74, $07              ; Color 12  Yellow
    db $77, $07              ; Color 13  White
    db $33, $03              ; Color 14  LightGray   (not used yet)
    db $27, $02              ; Color 15  Green       (not used yet)
    
    
    