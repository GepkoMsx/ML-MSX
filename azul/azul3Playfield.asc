;; ==[ AZUL3Playfield ]==================================================
;;
;; show the playfield
;; fabriek to the left, 2 boards to the right
;;
    
picbord1    equ $4000
pictiles    equ $5100
picfabriek  equ $5600
BELOW       equ $D5
    
; Draws the playfield
Azul3Playfield:
    xor a                    ; Reset the scrolling
    out ($99), a
    ld a, $97                ; Register 23
    out ($99), a
    call Waitvdp
    
    ld a, 0
    call Border
    
    ld HL, Screen5_Table
    call screen              ; screen 5 not visible
    call Waitvdp
    
    ld HL, COLORMAP
    call SetPalette16
    call Waitvdp
    
    ld HL, CLEARSCREEN       ; make screen clean with hmmv page0
    call HMMV
    call Waitvdp
    
    
    ld HL, HMMCFabriek       ; Draw factory
    call HMMCNoData
    ld HL, picfabriek
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 0
    
    ld HL, HMMCBord          ; Draw board player 1
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 212/2
    
    ld HL, HMMCBord          ; Draw board player 2
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCTiles         ; Prepare tiles
    call HMMCNoData
    ld HL, pictiles
    call RLESendVDP
    
    
    ld a, $40                ; Screen on
    out ($99), a
    ld a, $81                ; Write to  R#1
    out ($99), a
    
    ret
    
; ==[ Data ]====================================================
HMMCFabriek:
    dw $0000, $0000          ; dx, dy
    dw $0080, $009F          ; nx, ny
    db $00, $00, $F0         ; color, arg, command
HMMCBord:
    dw $007e, $0000          ; dx, dy
    dw $0082, $006A          ; nx, ny
    db $00, $00, $F0         ; color, arg, command
HMMCTiles:
    dw $0000, BELOW          ; dx, dy
    dw $0082, $0014          ; nx, ny
    db $44, $00, $F0         ; color, arg, command
CLEARSCREEN:
    dw 0, 0, 256, 256        ; HMMV header voor LEEG scherm page0, color 0
    db 0, 0, $C0
    

    
    
    