;; ==[ AZUL3Playfield ]==================================================
;;
;; show the playfield
;; fabriek to the left, 2 boards to the right
;;
    
    .equ picbord1, 0x4000
    .equ pictiles, 0x5100
    .equ picfabriek, 0x5600
    .equ BELOW, 0xD5

    
    .section .text
    .global  Azul3Playfield

    .include "Macros.asc"
      
; Draws the playfield
Azul3Playfield:
    SetVDP 23, 0                  ; Reset the scrolling
    call Waitvdp
    
    SetVDP 7,0                      ; border color 0
    
    SetScreen 5, off
    
    ld HL, COLORMAP
    call SetPalette16
    call Waitvdp
    
    ld HL, CLEARSCREEN             ; make screen clean with hmmv page0
    call HMMV
    call Waitvdp
    
    ld HL, HMMCFabriek             ; Draw factory
    call HMMCNoData
    ld HL, picfabriek
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 0
    
    ld HL, HMMCBord                ; Draw board player 1
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCBord+2
    ld (HL), 212/2
    
    ld HL, HMMCBord                ; Draw board player 2
    call HMMCNoData
    ld HL, picbord1
    call RLESendVDP
    
    ld HL, HMMCTiles               ; Prepare tiles
    call HMMCNoData
    ld HL, pictiles
    call RLESendVDP
    
    SetVDP 1, 0x40                  ; Screen on
    ret

    .section .data
    
HMMCFabriek:
    .word 0x0000, 0x0000           ; dx, dy
    .word 0x0080, 0x009F           ; nx, ny
    .byte 0x00, 0x00, 0xF0         ; color, arg, command

HMMCBord:
    .word 0x007E, 0x0000           ; dx, dy
    .word 0x0082, 0x006A           ; nx, ny
    .byte 0x00, 0x00, 0xF0         ; color, arg, command

HMMCTiles:
    .word 0x0000, BELOW            ; dx, dy
    .word 0x0082, 0x0014           ; nx, ny
    .byte 0x44, 0x00, 0xF0         ; color, arg, command
    
CLEARSCREEN:                       ; HMMV header voor LEEG scherm page0, color 0
    .word 0x0000, 0x0000           ; dx, dy
    .word 0x0100,0x01000           ; nx, ny
    .byte 0x00, 0x00, 0xC0         ; color, arg, command 
    

    
    
    