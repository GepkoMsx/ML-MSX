;; CALL HMMMnumber
;;
;; INPUT
;; A = number (0-9)
;; DE = location (x,y) (stays intact)
;; BELOW = Ycoord of the tiles.lr5 in vram.
;; NUMBERSX = address of start positions (X-coord) of the number tiles.lr5 in vram
;;
;; loaded numbers from tiles.lr5 loaded in vram (prepared by azul-3Playfield.asc)
    
HMMMnumber:                  ; A = number, DE = location (x,y)
    cp 5
    jr NC, HMMMnumberRow2
    ld c, BELOW              ; C = L-SY
    
HMMMnumberRow2cont:
    ld HL, NUMBERSX          ; b = xxx a = nr, c = lsy => b = 0, c = nr, a = lsy
    ld b, a                  ; b = nr
    ld a, c                  ; a = lsy
    ld c, b                  ; c = nr
    ld b, 0                  ; b = 0
    add HL, bc               ; HL points to L-SX
    ld b, a                  ; b = L-SY
    
    call waitvdp
    ld a, 32                 ; start HMMM
    out (VDPC), a            ; auto-increment (geen $80) vanaf register 32
    ld a, $80 + 17           ; schrijf ($80) naar R17
    out (VDPC), a
    
;2SX,2SY, 2DX,2DY,2MX,2MY,1CLR,1ARG,1CMD
    ld a, (HL)
    out (VDPR), a            ; L-sx
    xor a
    out (VDPR), a            ; H-sx
    
    ld a, b
    out (VDPR), a            ; L-sy
    xor a
    out (VDPR), a            ; H-sy
    
    ld a, d
       out (VDPR), a            ; L-dx
    xor a
    out (VDPR), a            ; H-dx
    
    ld a, e
    out (VDPR), a            ; L-dy
    xor a
    out (VDPR), a            ; H-dy
    
    ld a, 10
    out (VDPR), a            ; L-nx
    xor a
    out (VDPR), a            ; H-nx
    
    ld a, 10
    out (VDPR), a            ; L-ny
    xor a
    out (VDPR), a            ; H-ny
    
    xor a
    out (VDPR), a            ; color
    xor a
    out (VDPR), a            ; arg
    ld a, $D0
    out (VDPR), a
    ret
HMMMnumberRow2:
    ld C, BELOW+10           ; c = L-sy
    jr HMMMnumberRow2cont