;; CALL ShowTileSprite

    .section .text
    .global ShowSelector

; show the selector at <DE>
ShowSelector:                      ; show Selector at DE, spritenr 0, pattern 52
    dec d                          ; compensate for the selector to be 1 bigger than tiles.
    dec e                          ; Submitted DE should be tile coord.

    ld hl, 0x7600                   ; do SAT
    call SetVramWrite
    ld   a, E
    out (VDPD), a                   ; E=Y
    ld   a, D
    out (VDPD), a                   ; D=X
    ld   a, 52
    out (VDPD), a                   ; 52 is pattern of selector
    ld   a, 0x40
    out (VDPD), a                   ; CC=1 (Gebruik SCT), Kleur=0
    
    ld de, SpriteColors + 13       ; colors for selector
    ld hl, 0x7400                   ; now load the colortable for this sprite
    call SetVramWrite
    ld a, (de)
    ld b, 16                       ; 16 lijnen kleur
.SCTloop:
    out (VDPD), a
    djnz .SCTloop
    ret