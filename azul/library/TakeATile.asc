;; CALL TakeATile

    .section .text
    .global TakeATile

; Take a tile from the bag = A = type.
TakeATile:                         ; (0-4 for blue, yellow, red, black, white)
    ld HL, TILESINBAG              ; Count total tiles left.
    ld b, 5
    ld a, 0
.loop:
    ld c, (HL)
    inc HL
    add a, c
    djnz .loop
    ld e, a                        ; E = total
.rnd:
    ld a,r                         ; take a random nr
    ld b,a
    ld a,(RND)
    xor b
    ld (RND),a

    cp e
    jr NC, .rnd                    ; the random nr was too big
                            ; a is an in-range number, now find its color/type
    ld HL, TILESINBAG
    ld b, 5
.typeloop:
    ld c, (HL)
    cp c                           ; is it a match?
    jr C, .found
    inc HL
    sub a, c                       ; remve the stack of this color, and check next.
    djnz .typeloop

.found:                            ; b = the stack (1-5) HL point address
                            ; 5 = blue, 4= yellow, 3= red 2 = black 1 = white
    ld a, (HL)
    or a
    jp z, .rnd                     ; pile is empty, try again.
    dec a
    ld (HL), a                     ; remove one from pile
    ld a, 5
    sub a, b                       ; a = 0-4 for the right type.
    ret

    .section .data
    .global TILESINBAG

TILESINBAG:
    .byte 20,20,20,20,20           ; 20 blue, 20 yellow, 20 red, 20 black, 20 white tiles.
RND:
    .byte 42                       ; the last random nr