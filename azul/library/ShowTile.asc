;; CALL ShowTile

    .section .text
    .global ShowTile

    .include "Macros.asc"
    
; show tile graphic  C = type, DE = location, 
ShowTile:
    ld HL, TILESX
    LD b, 0
    ADD HL, bc                     ; HL = HL + A, HL points to right tile
    ld a, (HL)                     ; A = SX
    
    ld HL, TILEHMMM
    ld (HL), a                     ; sx
    inc hl
    inc hl                         ; sy
    inc hl

    inc hl
    ld (HL), d                     ; dx
    inc hl
    inc hl
    ld (HL), e                     ; dy

    ld HL, TILEHMMM                ; put tile on screen
    VdpCopy HMMM, HL               ; VRAM to VRAM transfer. <HL> : Address of header
    ret

    .section .text

TILEHMMM:
    .word 0x0000, BELOW            ; 2sx, 2sy
    .word 0x0000, 0x0000           ; dx dy
    .word 10, 10                   ; mx, my
    .byte 0x0, 0x0                 ; 1CLR, 1ARG
