;; CALL ShowTile

; show tile graphic  C = type, DE = location, 
ShowTile:
    ld HL, TILESX
    LD b, 0
    ADD HL, bc               ; HL = HL + A, HL points to right tile
    ld a, (HL)               ; A = SX
    
    ld HL, TILEHMMM
    ld (HL), a               ; sx
    inc hl
    inc hl                   ; sy
    inc hl

    inc hl
    ld (HL), d               ; dx
    inc hl
    inc hl
    ld (HL), e               ; dy

    ld HL, TILEHMMM          ; put tile on screen
    call Waitvdp
    CALL HMMM                ; VRAM to VRAM transfer. <HL> : Address of header
    ret

TILEHMMM:
    db $00, $00              ; 2sx
    dw BELOW                 ; 2sy
    db $00,$00,$00,$00       ; dx dy
    dw 10, 10                ; mx, my
    db $0, $0, $D0           ; 1CLR,1ARG,1CMD
