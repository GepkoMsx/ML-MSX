;; CALL PrintScore (A=player), PrintScoreP1 or PrintScoreP2
;;
;; prints the score on screen with "HMMMnumber.asc" 
;; with numbers from tiles.rl5. 
;;
;; INPUT
;; - A : Player (0, 1)
;; - SCORE: address to 2 bytes of score of player 1 and 2 in BCD format
;; 
;; USES:
;; - HMMMnumber
    .section .text
    .global PrintScore

PrintScore:
    or a
    jp nz, PrintScoreP2
    
PrintScoreP1:
    ld e, 0x1F                      ; y of score player 1.
    ld hl, SCORE
    
PrintScoreNext:
    ld b, (HL)
    ld d, 0x84                      ; x of 1st digit
    ld a, b
    push bc
    
    rrca                           ; rotate right 4x
    rrca
    rrca
    rrca
    and 0x0F
    call HMMMnumber                ; print 1st digit
    
    pop bc
    ld d, 0x8E                      ; x of 2nd digit
    ld a, b
    
    and 0x0F
    call HMMMnumber                ; print 2nd digit
    ret
    
PrintScoreP2:
    ld e, 0x89                      ; y of score player 2
    ld HL, SCORE+1
    
    jr PrintScoreNext