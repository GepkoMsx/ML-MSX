;; CALL ShowTileSprite

    .section .text
    .global ShowTileSPrite

; show a tile (2 sprites, same location) DE = xy, B = type, C = spritenr
ShowTileSprite:                    ; show a tile (2 sprites, same location)
                             ; 
    push BC                        ; Needed at color table

    ld a, b                        ; A = type

    ld hl, 0x7600                   ; do SAT
    LD B, 0                        ; point HL to right vram address
    SLA C                          ; for sat its 4 bytes per sprite, we use 2, so spritenr*8
    RL B
    SLA C
    RL B
    SLA C
    RL B                           ; bc = bc*8
    ADD HL, BC                     ; HL = HL + BC
    
    ld c, a                        ; 4 patterns per sprite, 2 sprites per type, so type*8 is needed
    SLA C                          ; for sat its 4 bytes per sprite, we use 2, so spritenr*8
    SLA C
    SLA C                          ; c = c*8
    
    call SetVramWrite
    call .pushSATentry             ; C = pattern DE = X,Y

    inc c
    inc c
    inc c
    inc c                          ; next pattern

    call .pushSATentry             ; C = pattern DE = X,Y

    pop bc                         ; now load the colortable for this sprite
                             ; DE = xy, B = type, C = spritenr
                             ; 16 colors per sprit, 2 sprites so c*32
    ld a, b                        ; a = type
    ld h, 0
    ld l, c                        ; hl = c
    ADD HL, HL                     ; HL * 2
    ADD HL, HL                     ; HL * 4
    ADD HL, HL                     ; HL * 8
    ADD HL, HL                     ; HL * 16
    ADD HL, HL                     ; HL * 32

    ld bc, 0x7400
    ADD HL, BC                     ; HL = HL + BC
    call SetVramWrite

    ld   hl, SpriteColors          ; colors are 1 byte per sprite, so type*2
    add a, a
    ld b, 0
    ld c, a
    add hl, bc

    call .pushSCT1c
    inc hl
    call .pushSCT1c
    ret

.pushSCT1c:                        ; hl = address of color
    ld a, (hl)
    ld   b, 16                     ; 16 lijnen kleur
.SCTloop:
    out (VDPD), a
    djnz .SCTloop
    ret

.pushSATEntry:
    ld   a, E
    out (VDPD), a                   ; E=Y
    ld   a, D
    out (VDPD), a                   ; D=X
    ld   a, C
    out (VDPD), a                   ; C=Pattern
    ld   a, 0x40
    out (VDPD), a                   ; CC=1 (Gebruik SCT), Kleur=0
    ret