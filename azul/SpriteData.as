; Spritedata. The SpritePatterns and SpriteColors
; 2 sprites per tile
; Patternorder: 0 = blue, 8 = yellow, 16 = red, 24 = black 32 = white, 40 = 1stplayer (3sprite)
;               56 = selector (1 sprite)

SpritePatterns:
    ; BLUE
    db %11111111, %10000000, %10111111, %10100001, %10101101 ; 1 left blue
    db %10101101, %10100001, %10111111, %10000000, %11111111
    db 0,0,0,0,0,0
    db %11000000, %01000000, %01000000, %01000000, %01000000 ; 1 right
    db %01000000, %01000000, %01000000, %01000000, %11000000
    db 0,0,0,0,0,0
    db %00000000, %01111111, %01000000, %01011110, %01010010 ; 2 left light blue
    db %01010010, %01011110, %01000000, %01111111, %00000000
    db 0,0,0,0,0,0
    db %00000000, %10000000, %10000000, %10000000, %10000000 ; 2 right
    db %10000000, %10000000, %10000000, %10000000, %00000000
    db 0,0,0,0,0,0

