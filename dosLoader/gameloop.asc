;;; first try on a game loop (need to get out of dosloader?!)

GameLoop:
    
WaitVBlank:                        ; Wait on V-Blank (Synchronize)
    ld hl, JIFFY
    ld a, (hl)                     ; read low byte of Jiffy clock
wait:
    cp (hl)                        ; changed?
    jr z, wait

    ; --- START METING (Kleur Wit - Kleur 15) ---
    di
    ld   a, 0xF8                    ; Kleur rood (als je rood ziet missen we frames!)
    out  (0x99), a                  ; Schrijf data naar VDP register poort
    ld   a, 128 + 7                ; 128 = Register schrijven, 7 = Border register
    out  (0x99), a
    ei

    ; vetraing
    ld b, 0xff
extra:
    ld ix, (0x8000)
    ld ix, (0x8000)
    ld ix, (0x8000)
    ld ix, (0x8000)
    ld ix, (0x8000)

    djnz extra

    ; count
    ld a, (COUNTER)
    inc a
    cp 50
    call z, ONESEC
    ld (COUNTER),a

    ; 2. Input lezen
    call GetActionKeys             ; A will be:
                        ; bit   7    6    5    4    3       2     1    0
                        ;       →	 ↓	  ↑    ←  return   tab   esc space
    bit 1, a
    jp nz, EXIT                    ; ESC = exit

    push af
    bit 4, a
    call nz, LEFT                  ; hello 2
    pop af

    bit 7, a
    call nz, RIGHT                 ; hello 1


; --- STOP METING (Kleur Zwart - Kleur 1) ---
    di
    ld   a, 0xF1                    ; Kleur 1 = Zwart
    out  (0x99), a                  ; (Dubbele out voor timing stabiliteit)
    ld   a, 128 + 7
    out  (0x99), a
    ei

    jr GameLoop

LEFT:
    ld   e, '<'                    ; Karakter om te printen
    ld c, 0x06
    call BDOS
    ret

RIGHT:
    ld   e, '>'                    ; Karakter om te printen
    ld c, 0x06
    call BDOS
    ret


ONESEC:
    ld a, (COUNTER+1)              ; secondeteller
    inc a
    cp 60
    call z, reset
    ld (COUNTER+1), a

    ld   e, '.'                    ; Karakter om te printen
    ld c, 0x06
    call BDOS
    xor a
    ret

reset:
    ld   e, 'o'                    ; Karakter om te printen
    ld c, 0x06
    call BDOS
    xor a
    ret
