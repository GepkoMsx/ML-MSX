{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build File",
            "type": "shell",
            //"command": "d:\\msx\\code\\vasm\\compile.cmd",
            "command": "D:\\MSX\\code\\vasm\\bin\\VasmBuilder.exe",
            "args": [
                "${fileBasename}",
                "${fileDirname}"
            ],
            "options": {
                "cwd": "D:\\MSX\\code\\vasm\\bin"
            },
            "group": {
                "kind": "build",
                "isDefault": "**/*.as?"
            },
            "problemMatcher": {
                "owner": "vasm",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(error)\\s+\\d+\\s+in\\s+line\\s+(\\d+)\\s+of\\s+\"(.+?)\":\\s+(.*)$",
                    "severity": 1,
                    "line": 2,
                    "file": 3,
                    "message": 0
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Project",
            "type": "shell",
            "command": "D:\\MSX\\code\\azul\\buildazul.cmd",
            "args": [
                "/lib",
                "/main"
            ],
            "group": {
                "kind": "build",
                "isDefault": "**/*.as?"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Build full Project",
            "type": "shell",
            "command": "D:\\MSX\\code\\azul\\buildazul.cmd",
            "group": {
                "kind": "build",
                "isDefault": "**/*.as?"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}