;; CALL StopVDP
;;
;; stops the vdp with whatever its doing.

StopVDP:
    
    ld a, 46            ; Load Register 46 (Command Register) via R17
    out ($99), a
    ld a, $91           ; $80 (write) + $11 (R17) = $91 (indirect register)
    out ($99), a
    
    xor a               ; A = 0 (STOP-command)
    out ($9b), a
                
    xor a               ; Reset Status Register to 0 
    out ($99), a
    ld a, $8f           ; R15 = 0
    out ($99), a
    ret