;; CALL ScrollUp8
;;
    
; Scrolls a screen 8 picure upwards
ScrollUp8:
    ld b, 212/3
    
SU8VBlank:
    xor a                    ; Kijk naar Status register 0
    out ($99), a             ; waarde 0
    ld a, $8F                ; $8F = Register 15 (Status Pointer)
    out ($99), a             ; de VDP staat nu op SR#0
    
SU8VBlankWait:               ; Wait on V-Blank (Synchronize)
    in   a,(#99)             ; Wacht nu tot hij weer 0 is
    rlca
    jr  nc, SU8VBlankWait
    
    ; TESTER
    ; ld   a, $1C         ; Kleur rood (als je rood ziet missen we frames!)
    ; out  ($99), a       ; Schrijf data naar VDP register poort
    ; ld   a, 128 + 7     ; 128 = Register schrijven, 7 = Border register
    ; out  ($99), a
    ; /TESTER
    
    exx
    call SU8oneline
    exx
    
    ; TESTER
    ; ld   a, $00         ; Kleur 1 = Zwart
    ; out  ($99), a       ; (Dubbele out voor timing stabiliteit)
    ; ld   a, 128 + 7
    ; out  ($99), a
    ; /TESTER
    
    djnz SU8VBlank
    ret
    
scroll_waarde:
    db 0                     ; 
    
SU8oneline:
    ; --- Stap 1: Kopieer blok omhoog (HMMM) ---
    ld a, (scroll_waarde)
    ld c, a
    add a, 3
    ld (scroll_waarde), a
    out (#99), a             ; Data
    ld a, 128 + 23           ; Register 23
    out (#99), a             ; Commando
    
; vanboven de zwarte band aanbrengen (de pagina scrolt als een cylinder)
    ld HL, SU8Clear_HMMV+2
    ld (HL), c
    
    ; --- Stap 2: Teken zwarte lijn onderaan (HMMV) ---
    dec hl
    dec hl
    
    ld a, 36                 ; auto-increment (geen $80) vanaf register 36
    out (VDPC), a
    ld a, $80 + 17           ; schrijf ($80) naar R17
    out (VDPC), a
    
    ld b, 11
    ld c, VDPR
    
HMMVHeaderLoop2:
    outi                     ; - out (c), (hl) - inc hl - dec b
    jr nz, HMMVHeaderLoop2
    ret
    
; --- Tabel voor het verplaatsen van de pixels ---
SU8Scroll_HMMM:
    dw 0, 8                  ; Bron X, Y (begin bij regel 1)
    dw 0, 0                  ; Doel X, Y (kopieer naar regel 0)
    dw 256, 212-8            ; Breedte (256), Hoogte (alle lijnen minus 1)
    db 0, 0                  ; Kleur (nSU8vSU8tSU8), Richting (vooruit)
    db $D0                   ; Commando: HMMM (High speed move VRAM-VRAM)
    
; --- Tabel voor de zwarte lijn ---
SU8Clear_HMMV:
    dw 0, 212-3              ; X, Y (de allerlaatste regel)
    dw 256, 3                ; Breedte (256), Hoogte (1 pixel lijn)
    db 0, 0                  ; Kleur (0 = zwart), Richting
    db $C0                   ; Commando: HMMV (High speed move VRAM fill)
    
    
    
    