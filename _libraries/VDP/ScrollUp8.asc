;; CALL ScrollUp8
    
    .section .text
    .global ScrollUp8

    .include "Macros.asc"

; Scrolls a screen 8 picure upwards
ScrollUp8:
    ld b, 212/3
    
SU8VBlank:
    SetVDP 15, 0                   ; Kijk naar Status register 0
    
SU8VBlankWait:                     ; Wait on V-Blank (Synchronize)
    in   a, (0x99)                 ; Wacht nu tot hij weer 0 is
    rlca
    jr  nc, SU8VBlankWait
    
    ; TESTER
    ; ld   a, 0x1C         ; Kleur rood (als je rood ziet missen we frames!)
    ; out  (0x99), a       ; Schrijf data naar VDP register poort
    ; ld   a, 128 + 7     ; 128 = Register schrijven, 7 = Border register
    ; out  (0x99), a
    ; /TESTER
    
    exx
    call SU8oneline
    exx
    
    ; TESTER
    ; ld   a, 0x00         ; Kleur 1 = Zwart
    ; out  (0x99), a       ; (Dubbele out voor timing stabiliteit)
    ; ld   a, 128 + 7
    ; out  (0x99), a
    ; /TESTER
    
    djnz SU8VBlank
    ret
    
SU8oneline:
    ; --- Stap 1: Kopieer blok omhoog (HMMM) ---
    ld a, (scroll_waarde)
    ld c, a
    add a, 3
    ld (scroll_waarde), a
    SetVDP 23, a
    
    ; vanboven de zwarte band aanbrengen (de pagina scrolt als een cylinder)
    ; --- Stap 2: Teken zwarte lijn onderaan (HMMV) ---
    ld HL, SU8Clear_HMMV+2
    ld (HL), c
    dec hl
    dec hl

    VdpCopy HMMV, HL
    ret


    .section .data

scroll_waarde:
    .byte 0                        ; 

; --- Tabel voor het verplaatsen van de pixels ---
; SU8Scroll_HMMM:
;     .word 0, 8                     ; Bron X, Y (begin bij regel 1)
;     .word 0, 0                     ; Doel X, Y (kopieer naar regel 0)
;     .word 256, 212-8               ; Breedte (256), Hoogte (alle lijnen minus 1)
;     .byte 0, 0                     ; Kleur (nSU8vSU8tSU8), Richting (vooruit)
;     .byte 0xD0                     ; Commando: HMMM (High speed move VRAM-VRAM)
    
; --- Tabel voor de zwarte lijn ---
SU8Clear_HMMV:
    .word 0, 209                   ; X, Y (de allerlaatste regel)
    .word 256, 3                   ; Breedte (256), Hoogte (1 pixel lijn)
    .byte 0, 0                     ; Kleur (0 = zwart), Richting
    
    
    
    