;; CALL Screen
;; Switch to the right screen mode without BIOS call.
;; Vram not properly initialized probably
;;
;; screen 0ff, no sprites!
;;
;; INPUT
;; - HL points to the right table (in this file)

Screen:
    ld b, 10            ; We gaan 5 registers zetten
Screen.loop:
    ld a, (hl)          ; Pak de waarde uit de tabel
    inc hl              ; Stuur waarde naar VDP data
    out  ($99), a       
    
    djnz Screen.loop
    ret

Screen8_Table:
    db $0E, $80         ; Reg 0: Mode Select (Screen 8)
    db $00, $81         ; Reg 1: Display OFF, 16KB VRAM chips, Interrupts OFF
    db $1F, $82         ; Reg 2: Name Table Base (Adres van het schermgeheugen)
    db $2A, $88         ; Reg 8: Color Mode (Bit 3 aan voor 256-kleuren/Vijk-modus)
    db $82, $89         ; Reg 9: 50Hz (PAL) en 212 lines

Screen5_Table:
    db $06, $80         ; Reg 0: Screen Mode (Screen 5)
    db $00, $81         ; Reg 1: Display OFF / 16KB chips
    db $1F, $82         ; Reg 2: Name Table Base
    db $2A, $88         ; Reg 8: Color Mode (0 voor Screen 5)
    db $82, $89         ; Reg 9: 50Hz (PAL) en 212 lines
