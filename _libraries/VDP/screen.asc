;; CALL Screen
;; Switch to the right screen mode without BIOS call.
;; Vram not properly initialized probably
;;
;; INPUT
;; - HL points to the right table (in this file)

Screen:
    ld b, 10            ; We gaan 5 registers zetten
    di                  ; geen interrupts bij de vdp
Screen.loop:
    ld a, (hl)          ; Pak de waarde uit de tabel
    inc hl              ; Stuur waarde naar VDP data
    out  ($99), a       
    
    djnz Screen.loop
    ei                  
    ret

Screen8_Table:
    db $0E, $80         ; Reg 0: Mode Select (M5, M4, M3 aan voor Screen 8)
    db $60, $81         ; Reg 1: Display aan, 16KB VRAM chips, Interrupts aan
    db $1F, $82         ; Reg 2: Name Table Base (Adres van het schermgeheugen)
    db $0A, $88         ; Reg 8: Color Mode (Bit 3 aan voor 256-kleuren/Vijk-modus)
    db $82, $89         ; Reg 9: 50Hz (PAL) en 212 lines

Screen5_Table:
    db $08, $80         ; Reg 0: Screen Mode (Screen 5)
    db $60, $81         ; Reg 1: Display Enable / 16KB chips
    db $1F, $82         ; Reg 2: Name Table Base
    db $00, $88         ; Reg 8: Color Mode (0 voor Screen 5)
    db $82, $89         ; Reg 9: 50Hz (PAL) en 212 lines

Screen0_Table:
    db $00, $80         ; M5-M3 uit. (Voor 80 kolommen gebruik je $04)
    db $50, $81         ; 16KB VRAM, Display aan, Mode M1 geselecteerd
    db $00, $82         ; Adres $0000 in VRAM
    db $00, $88         ; Standaard tekstmodus operatie
    db $02, $89   