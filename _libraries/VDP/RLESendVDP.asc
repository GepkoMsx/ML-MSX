;; CALL RLESendVDP
;; Sends color data to VDP (2nd part of HMMC)
;; uses OTIR: soo screen must be disabled.
;;
;; INPUT:
;; - HL: startadress of RLE compressed picture-data
    
; Unpack RLE & send to VDP as colordata (HMMC). <HL> : Address of data.    
    .section .text
    .global RLESendVDP
    
    .include "macros.asc"

RLESendVDP:
    SetVDP 17, 44+0x80

    ld c, VDPR
Decode_VDP:
    ld a, (hl)                     ; [7T] Haal RUN-byte
    inc hl                         ; [6T]
    
    cp 0xFF
    ret z                          ; [5/11T] Ja -> Klaar!
    
    and a                          ; [4T] Is bit 7 aan? (Check via Sign flag)
    jp m, .IsRun                   ; [10T] Bit 7=1 -> Herhaling
    
.IsRaw:                            ; Bit 7=0, Bit 6=0 -> Raw data
                                   ; A bevat de lengte (1-63)
    ld b, a                        ; [4T] Lengte in B voor OUTI
.isRawLoop:
    outi
    jr nz, .isRawLoop
    jr Decode_VDP                  ; [12T] Volgende byte
    
.IsRun:                            ; Bit 7=1, Bit 6=0 -> Herhaling
    and 0x7F                       ; [7T] Maskeer bit 7 (lengte 1-127)
    ld b, a                        ; [4T] Lengte in B
    ld a, (hl)                     ; [7T] De kleur-byte
    inc hl                         ; [6T]
    
.RunLoop:
    out (c), a                     ; [12T] Direct naar VDP
    djnz .RunLoop                  ; [13T] 25 T-states per byte
    jr Decode_VDP                  ; [12T] Volgende byte