;; ==[ call Waitvdp ]===============================================
;; small function, but used a lot

    .section .text
    .global Waitvdp

; Wait till vdp ready           
Waitvdp:
    ld a, 2                        ; Selecteer status register 0 (S2)
    out (0x99), a
    ld a, 0x8F
    out (0x99), a
    
.loop:
    in a, (0x99)                   ; Lees status
    rrca                           ; Bit 0 is de CE (Command Executing) flag
    jr c, .loop                    ; Wacht zolang CE = 1
    
    xor a                          ; Reset status register naar 0 (belangrijk!)
    out (0x99), a
    ld a, 0x8F
    out (0x99), a
    ret
