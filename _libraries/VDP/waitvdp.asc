;; ==[ call Waitvdp ]===============================================
;; small function, but used a lot

    .section .text
    .global Waitvdp

    .include "macros.asc"

; Wait till vdp ready           
Waitvdp:
    SetVDP 15, 2                   ; Select status register 0 (S2)
    
.loop:
    in a, (VDPC)                   ; Read status
    rrca                           ; Bit 0 is  CE (Command Executing) flag
    jr c, .loop                    ; Wait till CE = 1
    
    SetVDP 15, 0                   ; Reset status register to 0 (important!)
    ret
