;; ==[ CALL Waitvdp ]===============================================

; Wait till vdp ready
Waitvdp:
    ld a, 2                  ; Selecteer status register 2 (S2)
    out ($99), a
    ld a, $8F
    out ($99), a
    
.Loop:
    in a, ($99)              ; Lees status
    rrca                     ; Bit 0 is de CE (Command Executing) flag
    jr c, .loop              ; Wacht zolang CE=1
        
    xor a                    ; Reset status register naar 0 (belangrijk!)
    out ($99), a
    ld a, $8F
    out ($99), a
    ret