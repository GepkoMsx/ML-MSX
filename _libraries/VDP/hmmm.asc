;; ==[ CALL HMMM ]===============================================
;; verplaatst een block vram -> vram
;;
;; INPUT
;; - HL : Adres HMMV header 
;; -> 2SX,2SY, 2DX,2DY,2MX,2MY,1CLR,1ARG,1CMD     (total 15 bytes)
;;
;; GEBRUIKT
;; - VDPC, VDPR variabelen.
;;
    
; VRAM to VRAM transfer. <HL> : Address of header        
HMMM:
    in a, (VDPC)             ; even status check om vdp te schonen
    
    ld a, 32                 ; auto-increment (geen $80) vanaf register 32
    out (VDPC), a
    ld a, $80 + 17           ; schrijf ($80) naar R17
    out (VDPC), a
    
    ld b, 15
    ld c, VDPR
    
HMMMHeaderLoop:
    outi                     ; ; - out (c), (hl) - inc hl - dec b
    jr nz, HMMMHeaderLoop
    ret