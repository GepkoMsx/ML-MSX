;; ==[ CALL DOSVersion ]===============================================
;; In MSX-DOS 1.0 one needs to do their own memory management
;; In MSX-DOS 2.0 One needs to ask the dos system for pages.
;;
;; USES:
;; - MSXDOSVER      [012] (1) byte stating the dos version (0,1 or 2)
;; - MEMMAPTBL      [--2] (2) word pointing to the MSX-DOS2 mapper functions
;;
;; DESCRIPTION:
;; So first check version, then determine what to do.
;;  A = Error (always zero)
;;  BC = MSX-DOS kernel version
;;  DE = MSXDOS2.SYS version number
;;
;; The check: A == 0 (no error)  not 0? -> NO MSXDOS
;;            B < 2                     -> MSX-DOS 1
;;            DE                        -> MSX-DOS 2 with DE the msxdos2.sys version 
;;
;; When msxdos2 found, call extended bios to get the memory mapper table.
;; Setup the set and reset jumptable.
    
DOSVersion:
    ld c, $6F                ; Check MSX-DOS version
    call BDOS                ; A = Error (always zero) BC = MSX-DOS kernel version DE = MSXDOS2.SYS version number
    
    or a                     ; check for error
    ld a, 0
    ret nz                   ; no msxdos (shouldn't happen)
    
    ld a, 2
    cp b
    jr z, .MemTbl             ; version = 2: MSXDOS2
    jr c, .MemTbl             ; version > 2: MSXDOS2
    
    dec a                    ; version < 2: msxdos1
    ld hl, MemSetSeg1
    ld de, MemResetSeg1
    jr .Save
    
.MemTbl:                     ; Get maptbl
    ld de, $0402             ; D=4 (Mapper Support), E=2 (Get Table Address)
    xor a                    ; A=0 (default)
    call EXTBIO              ; Extended bios call
    ld (MEMMAPTBL), hl       ; save in MEMMAPTBL
    
    ld a, 2
    ld hl, MemSetSeg2
    ld de, MemResetSeg2
    
.Save:
    ld (MSXDOSVER), a
    ld (MEMSET+1), hl
    ld (MEMRESET+1), de
    ret
    
    