;; ==[ CALL MemSetSeg2 ]===============================================
;; laadt het juiste memorymapper segment in het juist page. 
;; Werkt voor MSX-DOS2.
;;
;; INPUT:
;; - C: Page to load onto slot (1 or 2).
;; - B: Indexed segment we want new.  (The real segment in there is determinded here)
;;      - so start requesting 0, then 1 etc. Keeping track of 16 segments now, so max 256kb. 
;;        (excluding what MSX-DOS takes, or the one stuck in page 0 and 3.)
;;
;; USES:
;; - MEMNRBANKS  (1) : Bevat het aantal memoryslots (max 32 = 512kb) (alleen MSX-DOS 0,1)
;; - MEMPAGE3    (1) : Bevat de memory page dat voor page 3 gerbuikt wordt. Deze niet veranderen! (alleen MSX-DOS 0,1)
;; - MEMPAGE0    (1) : Bevat de memory page dat voor page 0 gerbuikt wordt. Deze niet veranderen! (alleen MSX-DOS 0,1)
;; - MEMSEGMENTS (16): Bevat de indexarray voor de uitgegeven segmenten.
    
MemSetSeg2:
    ld HL, MEMSEGMENTS             ; get Segment
    ld d, 0
    ld e, b
    add HL, DE                     ; HL is address of the segement-index we want to load.
    
    push BC                        ; load new segment on index b on page c, store new segment in a.
    
    ld hl, (MEMMAPTBL)             ; ALL_SEG: Allocate segment pointer
    ld a, 0                        ; A=0: User segment
    ld b, 0                        ; B=0: primary mapper
    call .CallHL                   ; simuleer call (hl)
    
    pop BC
    jr c, MemSSDOS2NEWNOMEM        ; Carry set = fout (geen geheugen meer)
                             ; A bevat nu het nieuwe segmentnummer!
    
    ld HL, MEMSEGMENTS             ; a = segment, b = index, c = page
    ld d, 0                        ; save the new choosen segment in the MEMSEGMENTS table
    ld e, b
    add HL, DE
    ld (HL), a                     ; load segment a on page  c
    ld b, a                        ; b = segment c = page
    jp MemResetSeg2Do
    
.CallHL:
    jp (hl)
    
MemSSDOS2NEWNOMEM:
    DI
    HALT
