;; ==[ CALL MemResetSeg2 ]===============================================
;; laadt het juiste memorymapper segment in het juist page. 
;; Werkt voor MSX-DOS2.
;;
;; INPUT:
;; - C: Page to load onto (1 or 2).
;; - B: Indexed segment we want.  (The real segment in there is determinded here)
;;      It is a segment we already requested before with MemLoadSegNew)
;;
;; USES:
;; - MEMSEGMENTS (16): Bevat de indexarray voor de uitgegeven segmenten.
    
MemResetSeg2:
    ld HL, MEMSEGMENTS       ; get Segment
    ld d, 0
    ld e, b
    add HL, DE               ; HL is address of the segement-index we want to load.
    ld b, (HL)               ; b = segment c = page
    
MemResetSeg2Do:
    ld a, c
    add a, a                 ; A = 2 of 4
    add a, c                 ; A = 3 of 6 (A * 3)
    add a, a                 ; A = 6 of 12 (A * 6)
    add a, $18               ; Voeg de basiswaarde toe ($18 = 24 decimaal)
    
    ld l, a
    ld h, 0                  ; HL is offset
    ld de,(MEMMAPTBL)
    add hl,de                ; HL = pointer PUT_P1 or PUT_P2
    ld a, b                  ; Het segmentnummer dat je van ALL_SEG kreeg
    
    call  .CallHL            ; Schakel het segment in
    ret
    
.CallHL:
    jp (hl)
    
    