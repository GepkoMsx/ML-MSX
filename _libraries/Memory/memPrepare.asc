;; ==[ CALL MemPrepare ]===============================================
;; Sets up the memory (basic, msx-dos1, msx-dos2)
;; fresh page 1 and 2
;; msx-basic swapped out
    .section .text
    .global MemPrepare

MemPrepare:

;; In MSX-DOS 1.0 one needs to do their own memory management
;; In MSX-DOS 2.0 One needs to ask the dos system for pages.
DOSVersion:
    ld c, 0x6F                     ; Check MSX-DOS version
    call BDOS                      ; A = Error (always zero) BC = MSX-DOS kernel version DE = MSXDOS2.SYS version number
    
    or a                           ; check for error
    ld a, 0
    ret nz                         ; no msxdos (shouldn't happen)
    
    ld a, 2
    cp b
    jr z, .MemTbl                  ; version = 2: MSXDOS2
    jr c, .MemTbl                  ; version > 2: MSXDOS2
    
    dec a                          ; version < 2: msxdos1
    ld hl, MemSetSeg1
    ld de, MemResetSeg1
    jr .Save
    
.MemTbl:                           ; Get maptbl
    ld de, 0x0402                  ; D=4 (Mapper Support), E=2 (Get Table Address)
    xor a                          ; A=0 (default)
    call EXTBIO                    ; Extended bios call
    ld (MEMMAPTBL), hl             ; save in MEMMAPTBL
    
    ld a, 2
    ld hl, MemSetSeg2
    ld de, MemResetSeg2
    
.Save:
    ld (MSXDOSVER), a
    ld (MEMSET+1), hl
    ld (MEMRESET+1), de
    
.Continue:
    cp 2
    jr z, memPrepareDone

MSXDOS1:
    call MemMapCheck               ; find the mempry mapper and check it
    call MemSwapPage1              ; page 1 and 2 have fresh RAM now.
                                   ; page 0 still has the bios, and page 3 is unchanged.
    
memPrepareDone:                    ; MSX-DOS2 has above setup already for page 1 and 2.
    ld BC, 0x0002                  ; index 0 in page 2
    call MEMSET
    ld BC, 0x0101                  ; index 1 in page 1
    call MEMSET
    ret


    .section .data
    .global MSXDOSVER, MEMNRBANKS, MEMPAGE0, MEMPAGE3, MEMMAPTBL, MEMSEGMENTS, MEMSET, MEMRESET

 ;; default header for the Memory library with MSX-DOS.  
MSXDOSVER:
    .byte 0x00                     ; 1  [012] MSX-DOS version (0,1,2)                               DOSVersion.asc
MEMNRBANKS:
    .byte 0x00                     ; 1  [01-] total nr of memory-mapped segments available.	     memMapCheck.asc
MEMPAGE0:
    .byte 0x00                     ; 1  [01-] Loaded segment in page 0			                     memMapCheck.asc
MEMPAGE3:
    .byte 0x00                     ; 1  [01-] Loaded segment in page 3			                     memMapCheck.asc
MEMMAPTBL:
    .byte 0x00, 0x00               ; 2  [--2] address of MAPTBL                                     DOSVersion.asc
MEMSET:
    .byte 0xC3, 0x00, 0x00         ; 3  [012] jump to right set-page function   (new page)             DOSVersion.asc
MEMRESET:
    .byte 0xC3, 0x00, 0x00         ; 3  [012] jump to right reset-page function (old page)           DOSVersion.asc
MEMSEGMENTS:
    .byte 0xFF, 0xFF, 0xFF, 0xFF   ; 16 [012] Array of segment requested			             memLoadSegment.asc
    .byte 0xFF, 0xFF, 0xFF, 0xFF
    .byte 0xFF, 0xFF, 0xFF, 0xFF
    .byte 0xFF, 0xFF, 0xFF, 0xFF
