;; ==[ CALL MemSwapPage1 ]===============================================
;; Swapt Page1 van BASIC ROM, naar RAM
;; Laadt page1 en 2 met "memory mapped ram" (roep dit dus aan vanuit page 0 of 3)
;;
;; INPUT:
;; - MEMNRBANKS (1) : Bevat het aantal memoryslots (max 32 = 512kb)
;; - MEMPAGE3   (1) : Bevat de memory page dat voor page 3 gerbuikt wordt. (Deze niet veranderen!)
;;
;; Werking:
;; page 2 & 3 hebben memory
;; zet dat slot ook op page 1.
;; 
;; Heeft ook memory fix voor memmapcheck. Probeert door te nummeren met de segmenten vanaf page3.
;; Dus page 3 heeft segment 0, dan page 2 segment 1, page 1 segment 2.
    
;; pages (what sees the Z80) and slots (where is the memory)
;; Poort 0xA8 (Primary Slot)
;; Het register op poort 0xA8 is als volgt ingedeeld (2 bits per page):
;; -Bits 0-1: Slot voor Page 0 (0x0000-0x3FFF)
;; -Bits 2-3: Slot voor Page 1 (0x4000-0x7FFF)
;; -Bits 4-5: Slot voor Page 2 (0x8000-0xBFFF)
;; -Bits 6-7: Slot voor Page 3 (0xC000-0xFFFF)
    
;; TODO: MEMPAGE0 check
    .section .text
    .global MemSwapPage1

MemSwapPage1:
    in a, (0xa8)
    ld b, a                        ; Isoleer de bits van Page 2 en schuif ze naar de positie van Page 1
    and 0b00110000                 ; Houd alleen bits 4-5 over (Page 2)
    rrca                           ; Verschuif 2 bits naar rechts
    rrca                           ; nu staan ze op positie 2-3
    ld c, a                        ; Bewaar dit "masker" in C
    
    rrca                           ; tussentijds expanded slot check doen (bewaar BC voor later!)
    rrca                           ; A bevat nu het Primary Slot nummer (0, 1, 2 of 3)
    ld e, a                        ; bewaar slotnummer in DE
    ld d, 0
    ld hl, EXPTBL                  ; EXPTBL (vlaggen voor expanded slots)
    add hl, de
    push hl
    ld a, (hl)                     ; Lees vlag voor dit slot
    and 0x80                       ; Test bit 7 (1 = expanded)
    jr z, NoSubslot                ; Als niet expanded, zijn we klaar
    
                                   ; Lees het Subslot-register (0xFFFF) van dit slot
                                   ; Om 0xFFFF te kunnen lezen, moet het betreffende slot in Page 3 staan!
    
    ld a, e                        ; Pak slot nummer van Page 2
    rrca                           ; Schuif slot naar positie 6-7
    rrca
    and 0b11000000
    ld e, a
    
    ld a, b                        ; Pak originele poort 0xA8 waarde
    and 0b00111111                 ; Wis Page 3 (bits 6-7)
    
    or e                           ; Zet dit slot ook in Page 3
    out (0xa8), a                  ; Nu "kijkt" Page 3 naar hetzelfde slot als Page 2
    
    ld a, (0xffff)                 ; LEES het subslot register
    cpl                            ; MSX hardware bit-invert: subslot register is vaak geinverteerd
    ld e, a                        ; Bewaar waarde in E
    
                                   ; Kopieer subslot bits van Page 2 naar Page 1
                                   ; Subslot register indeling is gelijk aan 0xA8: Page 1 = bits 2-3, Page 2 = bits 4-5
    and 0b00110000                 ; Isoleer subslot bits Page 2
    rrca
    rrca                           ; Schuif naar positie Page 1
    ld h, a
    ld a, e
    and 0b11110011                 ; Wis oude Page 1 subslot bits
    or h                           ; Zet nieuwe bits erin
                                   ; Niet inverteren voor schrijven (doet msx zelf)
    ld (0xffff), a                 ; SCHRIJF terug naar subslot register
    
NoSubslot:                         ; nu verder met BC en slotselectie.. (en zetten we Page3 ook weer terug)
    ld a, b                        ; Maak Page 1 in de originele waarde leeg en voeg de nieuwe bits toe
    and 0b11110011                 ; Wis de huidige bits van Page 1 (bits 2-3)
    or c                           ; Voeg de bits toe die we uit Page 2 hebben gehaald
    
    out (0xa8), a                  ; Update Slot Register, Schrijf terug naar de hardware
    pop hl
    ld (hl), a                     ; Update BIOS mirror (veiligheid)
    ret
