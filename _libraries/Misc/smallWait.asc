;; ==[ CALL Wait ]===============================================
;; waits a few.  THis is busy waiting (cant do other things while waiting)
;;

; Wait one <b> frames
SmallWait:
    xor a                    ; Kijk naar Status register 0
    out ($99), a             ; waarde 0
    ld a, $8F                ; $8F = Register 15 (Status Pointer)
    out ($99), a             ; de VDP staat nu op SR#0

.VBlank:                     ; Wait on V-Blank (Synchronize)
    in a,(#99)               ; Wacht nu tot hij weer 0 is
    rlca
    jr nc, .VBlank

.waitEnd:                    ; Wacht tot de V-blank EINDIGT (vlag gaat van 1 naar 0)
    in a, ($99)              ; Dit voorkomt dat we dezelfde V-blank dubbel tellen.
    and $80
    jr nz, .waitEnd          ; Als 1, dan zitten we nog in de vblank

    djnz .VBlank
    ret
