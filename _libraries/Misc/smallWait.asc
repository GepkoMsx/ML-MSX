;; ==[ CALL Wait ]===============================================
;; waits a few.  THis is busy waiting (cant do other things while waiting)
;;

; Wait one <b> frames
    .section .text
    .global SmallWait

    .include "Macros.asc"

SmallWait:
    SetVDP 15, 0                   ; Kijk naar Status register 0

.VBlank:                           ; Wait on V-Blank (Synchronize)
    in a, (VDPC)                   ; Wacht nu tot hij weer 0 is
    rlca
    jr nc, .VBlank

.waitEnd:                          ; Wacht tot de V-blank EINDIGT (vlag gaat van 1 naar 0)
    in a, (VDPC)                   ; Dit voorkomt dat we dezelfde V-blank dubbel tellen.
    and 0x80
    jr nz, .waitEnd                ; Als 1, dan zitten we nog in de vblank

    djnz .VBlank
    ret
