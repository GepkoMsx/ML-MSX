;; ==[ CALL Wait ]===============================================
;; waits a few.  THis is busy waiting (cant do other things while waiting)
;;
;; INPUT:
;; DE - nr of tenth's of a sec to wait. ( 1 = 0.1 sec)

; Wait <DE> * 0.1 secs. 
    .section .text
    .global Wait

Wait:
    ld a, (MSXID)                  ; Lees de BIOS ID byte om te bepalen hoe snel de JIFFY teller is
    bit 7, a                       ; Controleer bit 7
    jr z, Wait_60hz                ; Als bit 7 nul is -> 60Hz

    ld c, 5                        ; Stel teller in op 50 voor 1 seconde (/10)
    jr Wait_Start

Wait_60hz:
    ld c, 6                        ; Stel teller in op 60 voor 1 seconde (/10)

Wait_Start:
    ld b, 0                        ; bc = 5 of 6
    call Multiply                  ; HL = BC * DE

    xor a                          ; Kijk naar Status register 0
    out (0x99), a                   ; waarde 0
    ld a, 0x8F                      ; 0x8F = Register 15 (Status Pointer)
    out (0x99), a                   ; de VDP staat nu op SR#0

WaitVBlank:                        ; Wait on V-Blank (Synchronize)
    in   a,(0x99)                   ; Wacht nu tot hij weer 0 is
    rlca
    jr  nc, WaitVBlank

    dec hl                         ; Nu we in V-blank zitten, tellen we af
    ld a, h
    or l
    ret z                          ; Klaar?

WaitEnd:                           ; Wacht tot de V-blank EINDIGT (vlag gaat van 1 naar 0)
    in a, (0x99)                    ; Dit voorkomt dat we dezelfde V-blank dubbel tellen.
    and 0x80
    jr nz, WaitEnd                 ; Als 1, dan zitten we nog in de vblank

    jr WaitVBlank