;; call FactoryTakeFromBag animation with a sprite

    .section .text
    .global FactoryTakeFromBag

    .include "Macros.asc"

FactoryTakeFromBag:                ; C = tile type, DE = XY of dest, HL = XY of source
    push hl                        ; Bewaar source XY voor later

    ; --- Bereken dX (X_dest - X_source) / 8 ---
    ld a, d                        ; D = X van bestemming
    sub h                          ; A = X_dest - X_source (kan negatief zijn!)
    sra a                          ; Shift Right Arithmetic (behoudt min-teken)
    sra a
    sra a                          ; A = dX per stap
    ld h, a                        ; Bewaar dX tijdelijk in H

    ; --- Bereken dY (Y_dest - Y_source) / 8 ---
    ld a, e                        ; E = Y van bestemming
    sub l                          ; A = Y_dest - Y_source (kan negatief zijn!)
    sra a                          ; Shift Right Arithmetic (behoudt min-teken)
    sra a
    sra a                          ; A = dY per stap
    ld l, a                        ; L = dY per stap. HL bevat nu (dX, dY)

    ; --- Setup voor de loop ---
    pop de                         ; DE bevat nu weer de originele source XY (was HL)
    ld b, 8                        ; Loop teller

.loop1:                            ; HL = dXdY stappen, BC = loop+type, DE = actuele XY
    push bc
    push de
    push hl

    ld b, c                        ; B = tile type
    ld c, 0                        ; C = spritenr
    call TileSpriteShow            ; Teken de sprite op huidige DE (XY)
    SetLastSprite16 2
    ld b, 2
    call SmallWait

    pop hl                         ; HL = dXdY stappen
    pop de                         ; DE = actuele XY
    
    ; --- Verplaats de sprite (werkt nu ook negatief!) ---
    ld a, d                        ; Bereken nieuwe X: X = X + dX
    add a, h
    ld d, a
    
    ld a, e                        ; Bereken nieuwe Y: Y = Y + dY
    add a, l
    ld e, a                        ; DE is nu geüpdatet met de nieuwe positie

    pop bc                         ; Herstel loop teller (B) en tile type (C)
    djnz .loop1

    SetLastSprite16 0
    ret
