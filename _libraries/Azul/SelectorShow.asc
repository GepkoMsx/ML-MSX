;; CALL SelectorShow

    .section .text
    .global SelectorShow

    .include "macros.asc"

; show the selector at address HL
SelectorShow:                      ; show Selector location in addres HL, spritenr 0, pattern 52
    ld D, (HL)
    inc HL
    ld E, (HL)
    dec d                          ; compensate for the selector to be 1 bigger than tiles.
    dec e                          ; Submitted DE should be tile coord.
    dec e                          ; not sure why e-=2

    ld hl, 0x7600                  ; do SAT
    SetVramWrite
    ld   a, E
    out (VDPD), a                  ; E=Y
    ld   a, D
    out (VDPD), a                  ; D=X
    ld   a, 52
    out (VDPD), a                  ; 52 is pattern of selector
    ld   a, 0x40
    out (VDPD), a                  ; CC=1 (Gebruik SCT), Kleur=0
    
    ld de, SpriteColors + 13       ; colors for selector
    ld hl, 0x7400                  ; now load the colortable for this sprite
    SetVramWrite
    ld a, (de)
    ld b, 16                       ; 16 lijnen kleur
.SCTloop:
    out (VDPD), a
    djnz .SCTloop
    ret