;; CALL PrintScore (A=player), PrintScoreP1 or PrintScoreP2
;;
;; prints the score on screen with "HMMMnumber.asc" 
;; with numbers from tiles.rl5. 
;;
;; INPUT
;; - A : Player (0, 1)
;; - SCORE: address to 2 bytes of score of player 1 and 2 in BCD format
;; 
;; USES:
;; - HMMMnumber
    .section .text
    .global ScorePrint, ScorePrintP1, ScorePrintP2

ScorePrint:
    or a
    jp nz, ScorePrintP2
    
ScorePrintP1:
    ld e, 0x1F                     ; y of score player 1.
    ld hl, SCORE
    
PrintScoreNext:
    ld a, (HL)
    ld c, a                        ; Bewaar het originele getal in register C

    ld b, 0                        ; Wis de honderdtallen-teller
.loop100:
    cp 100                         ; Is de waarde groter of gelijk aan 100?
    jr c, .print100                ; Zo nee, we zijn klaar met de honderdtallen
    sub 100                        ; Trek 100 af van de waarde
    inc b                          ; Verhoog de honderdtallen-teller
    jr .loop100                    ; Herhaal de check
.print100:
    push af                        ; Bewaar het restant (bijv. 24)
    ld a, b                        ; Zet het aantal honderdtallen (bijv. 1) in A
    ld d, 0x84                     ; A = number, DE = location (x,y)
    call ScoreNumber               ; print 1st digit
    
    pop af
    ld b, 0                        ; Wis de tientallen-teller
.loop10:
    cp 10                          ; Is de waarde groter of gelijk aan 10?
    jr c, .print10:                ; Zo nee, we zijn klaar met de tientallen
    sub 10                         ; Trek 10 af van de waarde
    inc b                          ; Verhoog de tientallen-teller
    jr .loop10                     ; Herhaal de check
.print10:
    push af
    ld a, b                        ; Zet het aantal tientallen (bijv. 2) in A
    ld d, 0x8E
    call ScoreNumber               ; print 2nd digit

    pop af
    ld d, 0x98
    call ScoreNumber               ; print 3rd digit
    ret
    
ScorePrintP2:
    ld e, 0x89                     ; y of score player 2
    ld HL, SCORE+1
    
    jr PrintScoreNext


    .section .data
    .global SCORE

SCORE:
    .byte 0x00, 0x00               ; Score of player1, player2 
