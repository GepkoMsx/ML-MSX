;; CALL FactoryFill
;; Draw random 20 tiles and place on factory.

    .section .text
    .global FactoryFill

FactoryFill:
    ld b, 20                       ; factory needs 20 tiles
.loop:
; 1. Now Choose a random tile from bag
    push bc
    call BagTakeATile              ; a = random tile-type from the bag
                                   ; (0-4 for blue, yellow, red, black, white)
    
; 1b. Calculate offset in memory in BC
    pop bc
    push bc
    ld d, a                        ; save a

    ld a, 20                       ; bc = 20-b
    sub b
    ld c, a
    ld b, 0
    ld a, d                        ; restore a

; 2. Now store the taken tile in TILESINFACTORY, so we know whats where. 
    ld HL, TILESINFACTORY
    add HL, BC                     ; HL is address of right tile in factory
    ld (HL), a                     ; save the type on tilesinfactory

; 3. Now DO the animation of the tile
    ld HL, FACTORYPOSITIONS
    add HL, BC
    add HL, BC

    ld d, (HL)                     ; d=dest-x
    inc hl
    ld e, (HL)                     ; e=dest-y

    LD c, a                        ; c = tiletype

    push bc
    push de
    ld HL, 0x0823
    call FactoryTakeFromBag        ; C = tile type, DE = XY of dest. (animation)

; 4. Now change sprite with picture
    pop de
    pop bc
    call TileShow                  ; tile graphic  C = type, DE = location, (replace sprite with picture)

; 5. repeat (total 20 times)
    pop bc
    djnz .loop
    ret