;; ==[ CALL DOS2ReadFile ]===============================================
;; Read a file from disk with MSX-DOS 2 using File Handle.
;;
;; INPUT:
;; - drive + Filename + extention filled in the FCB (Write $00 + "FILENAME.BIN" to start of FCB)
;; - DE: memory address to store the file to.
;; - DLFCB: the FCB block to read the filename from
;;
;; OUTPUT
;; - HL: nr of bytes read. (recordsize was 1)
;; - A: error (if not 0)
DOS2Handle:
    db 00                    ; The filehandle
    
; Read a file with Handle method. Fill: <DLFCB>, <DE> is RAM Address to write to. <A> = error
DOS2ReadFile:
    push DE                  ; DE was memory address
    call .FormatFcbName      ; Get a dos2 style filename from FCB
    ld a, 0                  ; Open the file with mode: Read Only
    ld c, $43
    call BDOS
    jr c, .Error             ; File not found
    ld a, b
    ld (DOS2Handle), a       ; Handle zit in A en B bij DOS2
    
    ld de, 0                 ; Get Filesize. Offset 0
    ld hl, 0
    ld a, 2                  ; Mode 2: Vanaf het einde
    ld c, $4A                ; _SEEK
    call BDOS                ; DE:HL bevat nu de grootte (voor kleine bestanden is HL genoeg)
    push hl                  ; Bewaar de grootte voor de READ call
    
    ld a, (DOS2Handle)       ; Back to start
    ld b, a
    ld de, 0
    ld hl, 0
    ld a, 0                  ; Mode 0: Vanaf het begin
    ld c, $4A                ; _SEEK
    call BDOS
    
    pop hl                   ; Read File. HL = filesize
    pop de                   ; DE = Doel in RAM
    ld a, (DOS2Handle)
    ld b, a
    ld c, $48
    call BDOS
    jr c, .Error
    
    ld a, (DOS2Handle)       ; Close the file handle
    ld b, a
    ld c, $45
    call BDOS
    
    xor a
    ret
    
.Error:
    ret                      ; Hier je error handling (A bevat de foutcode)
    
.FormatFcbName:              ; we nemen de FCB naam (1-11) en maken een kopie
                            ; zonder spaties, met punt en 0 terminated
    ld de, DLFCB + $0C       ; op de FCB vanaf offset 0C (de FCB wordt toch niet gebruikt.)
    ld hl, DLFCB+1           ; filename starts at +1 in FCB
    ld b, 8                  ; Eerst de 8 tekens van de naam
.CopyName:
    ld a, (hl)
    inc hl
    cp ' '                   ; Is het een spatie?
    jr z, .SkipName          ; Ja, stop met kopiëren van de naam
    ld (de), a
    inc de
.SkipName:
    djnz .CopyName           ; Doe dit 8 keer
    
    ld a, '.'                ; Voeg de punt toe
    ld (de), a
    inc de
    
    ld b, 3                  ; Voeg de extensie toe (3 tekens)
.CopyExt:
    ld a, (hl)
    inc hl
    cp ' '                   ; Is extensie korter dan 3?
    jr z, .DoneFN
    ld (de), a
    inc de
    djnz .CopyExt
    
.DoneFN:
    xor a                    ; Maak A nul
    ld (de), a               ; Null-terminator voor DOS 2
    ld de, DLFCB + $0C       ; DE is terug naar het begin van de filenaam
    ret