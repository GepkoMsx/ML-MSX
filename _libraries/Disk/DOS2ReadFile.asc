;; ==[ CALL DOS2ReadFile ]===============================================
;; Read a file from disk with MSX-DOS 2 using File Handle.
;;
;; INPUT:
;; - drive + Filename + extention filled in the FCB (Write $00 + "FILENAME.BIN" to start of FCB)
;; - DE: memory address to store the file to.
;; - DLFCB: the FCB block to read the filename from
;;
;; OUTPUT
;; - HL: nr of bytes read. (recordsize was 1)
;; - A: error (if not 0)
DOS2Handle:
    db 00                     ; de filehandle

DOS2ReadFile:
    push DE                   ; DE was memory address
    ; 1A. OPEN
    call DOS2RFFormatFcbName  ; get a dos2 style filename from FCB
    ld a, 0                   ; Mode: Read Only
    ld c, $43                 ; _OPEN function
    call BDOS                 ; DOS Call
    jr c, Error               ; Stop als bestand niet bestaat
    ld a, b
    ld (DOS2Handle), a        ; Handle zit in A en B bij DOS2

    ; 1B. get filesize
    ld de, 0            ; Offset 0  
    ld hl, 0
    ld a, 2             ; Mode 2: Vanaf het einde
    ld c, $4A           ; _SEEK
    call BDOS           ; DE:HL bevat nu de grootte (voor kleine bestanden is HL genoeg)
    push hl             ; Bewaar de grootte voor de READ call    

    ; 1C. Back to start
    ld a, (DOS2Handle)
    ld b, a
    ld de, 0
    ld hl, 0
    ld a, 0                 ; Mode 0: Vanaf het begin
    ld c, $4A               ; _SEEK
    call BDOS

    ; 2. READ
    pop hl                    ; filesize
    pop de                    ; Doel in RAM
    ld a, (DOS2Handle)
    ld b, a
    ld c, $48                 ; _READ function
    call BDOS
    jr c, Error

    ; 3. CLOSE
    ld a, (DOS2Handle)
    ld b, a
    ld c, $45                 ; _CLOSE function
    call BDOS

    xor a
    ret

Error:
    ; Hier je error handling (A bevat de foutcode)
    ret



DOS2RFFormatFcbName:    ; we nemen de FCB naam (1-11) en maken een kopie
                        ; zonder spaties, met punt en 0 terminated
                        ; op de FCB vanaf offset 0C (de FCB wordt toch niet gebruikt.)
    ld de, DLFCB + $0C
    ld hl, DLFCB+1      ; filename starts at +1 in FCB

    ld b, 8             ; Eerst de 8 tekens van de naam
DOS2RFCopyName:
    ld a, (hl)
    inc hl
    cp ' '              ; Is het een spatie?
    jr z, DOS2RFSkipName     ; Ja, stop met kopiëren van de naam
    ld (de), a
    inc de
DOS2RFSkipName:
    djnz DOS2RFCopyName      ; Doe dit 8 keer

    ; Voeg de punt toe
    ld a, '.'
    ld (de), a
    inc de

    ; Voeg de extensie toe (3 tekens)
    ld b, 3
DOS2RFCopyExt:
    ld a, (hl)
    inc hl
    cp ' '              ; Is extensie korter dan 3?
    jr z, DOS2RFDoneFN
    ld (de), a
    inc de
    djnz DOS2RFCopyExt

DOS2RFDoneFN:
    xor a               ; Maak A nul
    ld (de), a          ; Null-terminator voor DOS 2
    ld de, DLFCB + $0C  ; DE is terug naar het begin van de filenaam
    ret    