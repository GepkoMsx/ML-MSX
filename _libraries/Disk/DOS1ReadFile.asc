;; ==[ CALL DOS1ReadFile ]===============================================
;; Read a file from disk with MSX-DOS 1 using File Control Block. max size 64kb
;; Uses FCB on $005C
;; INPUT:
;; - drive + Filename + extention filled in the FCB (Write $00 + "FILENAME.BIN" to start of FCB)
;; - DE: memory address to store the file to.
;;
;; OUTPUT
;; - HL: nr of bytes read. (recordsize was 1)
;; - A: error (if not 0)

DOS1ReadFile:
    push DE
    
    ld hl, DLFCB + 12     ; clear the bottom part of FCB
    ld b, 25
DOS1ReadFile_loop:
    ld (hl), 0
    inc hl
    djnz DOS1ReadFile_loop

    ld de, DLFCB          ; OPEN FILE, default FCB Location
    ld c, $0F
    call BDOS
    or a               ; Check if A=0 (success)
    jr nz, DOS1ReadFile_error

    ld hl, 1            ; Set record size on 1 byte
    ld (DLFCB + 14), hl

    pop DE              ; Set the destination      
    ld c, $1A           ; SET DISK TRANSFER ADDRESS
    call BDOS

    ld hl, (DLFCB + 16)   ; HL = File size (low 16 bits) from FCB
    ld de, DLFCB          ; DE wijst naar de FCB
    ld c, $27           ; RANDOM BLOCK READ
    call BDOS
    
    or a               ; Check if A=0 (success)
    jr nz, DOS1ReadFile_error

    push HL             ; nr of record read

    ld de, DLFCB
    ld c, $10           ; CLOSE FILE
    call BDOS

    pop HL
    ret

DOS1ReadFile_error:
    ret                 ; A = error (not 0)



;FCB layout
    ; db $00                ; (00) Drive number
    ; db "FILENAME"         ; (01-08) Filename
    ; db "EXT"              ; (09-0B) Extention
    ; db $00                ; (0C) Extent number (low byte). Must be set (usually to zero) by the program before open
    ;                       ; or create. It is used and updated by sequential read and write, and also set by random read and write. 
    ; db $00                ; (0D) File attributes
    ; db $00                ; (0E) Extent number (high byte). Zeroed by open and create. For sequential read and write it is used 
    ;                       ; and updated as an extension to the extent number to allow larger files to be accessed. 
    ;                       ; Record size (low byte) for MSX-DOS 1 compatible block functions. 
    ; db $00                ; (0F) Record cound for CP/M functions
    ;                       ; Record size (high byte) for MSX-DOS 1 compatible block functions. 
    ; db $00, $00, $00, $00 ; (10-13) File size in bytes, lowest byte first. File size is exact, not rounded up to 128 bytes.
    ; db $00, $00, $00, $00 ; (14-17) Volume-id. This is a four byte number identifying the disk which this FCB is accessing.
    ; db $00, $00, $00, $00
    ; db $00, $00, $00, $00 ; (18-1F) Internal information. These bytes contain information to enable the file to be located on the disk.    
    ; db $00                ; (20) Current record within extent (0...127). Must be set (normally to zero) by the program before first sequential read or write. 
    ; db $00, $00, $00, $00 ; (21-24) Random record number, low byte first. This field is optional, it is required if random or block reads or writes are used. 
    