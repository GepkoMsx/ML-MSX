;; ==[ CALL DosLoader ]===============================================
;; dosloader. Loads files using MSX-DOS 1 style FCBs or MSX-DOS 2 filehandles
;; We want to be compatible with "vanilla MSX2"
;; But also work on extentions liks harddisks, SD cards etc
    
;; We need to be aware of MSX-DOS 2.0 for the way memory is 
;; allocated. (v1: do it yourself, v2: use the mapper extentions)
;; We use the Memory pack for that.
;; Uses different data-config as rawloader.
    
;; USES:
;; - NROFILES           ; equ: nr of files to load
;; - MemPack            ; The memory management package needs to be setup
;; - FILENAME           ; label pointing to the FILENAME-structure to load
;; - MSXDOSVER          ; msxdos version (from mempack)
;;
;; DELCARES:
;; - DLFCB              ; the FCB used by this and DOS1ReadFile.asc
;; - DOS1ReadFile.asc ; includes this library.
    
;; We load everything through page 1 or 2 on the right segment. 
;; So programs would start in the 4000-C000 range
;; and then can swap page 1 as needed. 
;; assume startadres = start of file.
    
; Loads <NROFILES> files from <FILENAME> structure into memory. Needs Mempack.
DosLoader:
    ld ix, FILENAME
    ld b, NROFILES
    
.loop:                             ; 1. Load the Right Segment in memory
    push bc                        ; B is loop counter
    
    ld a, (IX+12)                  ; Get high-byte of load address
    rlca                           ; shift bit 6-7 to bit 0-1
    rlca
    and 3                          ; keep bit 0-1
    ld c, a                        ; C is pagenr
    
    ld b, (ix + 13)
    bit 7, b
    jr nz, .reset                  ; add 0x80 to reset instead of set.
    call MEMSET                    ; C: Page (1 or 2),  B: Indexed segment
    jr .cont
.reset:
    res 7, b
    call MEMRESET
    
.cont:                             ; 2. Setup reading the file.
    ld l, (ix+11)                  ; Read the file, HL is destination addresss
    ld h, (ix+12)
    push hl
    
    push ix                        ; prepare the FCB and DE. We use FCB in dos2 as storage, not as FCB.
    pop  hl                        ; hl = ix
    ld de, DLFCB+1
    ld bc, 11
    ldir
    
    pop de                         ; Load:  DE: memory address, FCB filled.
    push de
    push ix
    ld a, (MSXDOSVER)              ; check version
    cp 2
    jr z, .DOS2
    or a
    ret z                          ; no msxdos, return
    call DOS1ReadFile              ; read with FCB
    
.loaded:                           ; 3. Check to RUN it  HL = Address
    pop ix
    pop hl                         ; HL = Address
    
    ld a, (ix+14)                  ; need to run it?
    or a
    jr z, .next
    
    ld de, .next                   ; run it
    push de                        ; fake call
    jp (hl)
    
.next:                             ; 4. Load next file.
    pop bc
    ld DE, 15                      ; size of FILES data block
    add ix, de
    djnz .loop
    ret
    
.DOS2:
    call DOS2ReadFile              ; Dos2 (it'll convert FCB to dos2 filename)
    jr .loaded
    
;; ==[ libraries ]====================================================
    .include "DOS1ReadFile.asc"
    .include "DOS2ReadFile.asc"
    
;; ==[ Data ]====================================================

    .pushsection .bss
DLFCB:
    .space 37                      ; Reserve 37 bytes for FCB
    
    .popsection
