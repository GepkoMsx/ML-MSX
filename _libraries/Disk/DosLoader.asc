;; ==[ CALL DosLoader ]===============================================
;; dosloader. Loads files using MSX-DOS 1.0 style FCBs
;; We want to be compatible with "vanilla MSX2"
;; But also work on extentions liks harddisks, SD cards etc

;; We need to be aware of MSX-DOS 2.0 for the way memory is 
;; allocated. (v1: do it yourself, v2: use the mapper extentions)
;; We use the Memory pack for that.
;; Uses different data-config as rawloader.

;; USES:
;; - NROFILES           ; equ: nr of files to load
;; - MemPack            ; The memory management package needs to be setup
;; - FILENAME           ; label pointing to the FILENAME-structure to load
;;
;; DELCARES:
;; - DLFCB              ; the FCB used by this and DOS1ReadFile.asc
;; - DOS1ReadFile.asc ; includes this library.

;; We load everything through page 1 or 2 on the right segment. 
;; So programs would start in the 4000-C000 range
;; and then can swap page 1 as needed. 
;; assume startadres = start of file.
DosLoader:    
    ld ix, FILENAME 
    ld b, NROFILES
DL_loop:
    push bc

    ld a, (IX+12)       ; Get high-byte of load address
    rlca                ; shift bit 6-7 to bit 0-1
    rlca             
    and 3               ; keep bit 0-1
    ld c, a             ; C is pagenr

    ld b, (ix + 13)
    bit 7, b
    jr nz, DL_reset     ; add $80 to reset instead of set.
    call MEMSET         ; C: Page (1 or 2),  B: Indexed segment
    jr DL_cont
DL_reset:
    res 7, b
    call MEMRESET
DL_cont:
    push ix             ; hl = ix
    pop  hl
    ld de, DLFCB+1
    ld bc, 11
    ldir

    ld l, (ix+11)       ; Read the file, HL is offset
    ld h, (ix+12)
    push hl
    ld d, h
    ld e, l
    push ix
    call DOS1ReadFile ; DE: memory address, FCB filled.
DL_loaded:
    pop ix
    pop hl

    ld a, (ix+14)       ; need to run it?
    or a
    jr z, DL_next

    ld de, DL_next:        ; run it
    push de             ; fake call
    jp (hl)
DL_next:
    pop bc
    ld DE, 15           ; size of FILES data block
    add ix, de
    djnz DL_loop

    ret


;; ==[ libraries ]====================================================
    include "DOS1ReadFile.asc"

;; ==[ Data ]====================================================

DLFCB:  
    defs 37, $00        ; Reserve 37 bytes for FCB
