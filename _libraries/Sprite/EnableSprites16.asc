;; CALL EnableSprites16

; Enables sprites for screen5, with 16x16 size. tables on 7400/7600/7800
EnableSprites16:
    ld a, $28                ; #28 to R8   (sprites on)
    out ($99), a
    ld a, $80+8
    out ($99), a

    ld a, $62                ; #62 to R1   (16x16 sprites)
    out ($99), a
    ld a, $80+1
    out ($99), a

    ld a, $0F                ; Sprite Pattern Table $7800-7FFF  #0F to R6
    out ($99), a
    ld a, $80+6
    out ($99), a
    
    ld a, $EF                ; Sprite Attribute Table $7600-767F   EF to R5, 00 to R11
    out ($99), a             ; Sprite Color table     $7400-$75FF
    ld a, $80+5
    out ($99), a

    ld a, $00
    out ($99), a
    ld a, $80+11
    out ($99), a

    ld a, $01                ; select VRAM write range 2nd 16KB ($4000-$7FFF)
    out ($99), a             ; $01 to R14
    ld a, $80+14
    out ($99), a
    ret