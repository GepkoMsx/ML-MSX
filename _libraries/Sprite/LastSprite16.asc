;; CALL LastSprite16

; close the spritearray C = spritenr
LastSprite16:
    ld   hl, $7600

    LD B, 0                  ; point HL to right vram address
    SLA C
    RL B
    SLA C
    RL B                     ; c = c*4 (in 16x16 mode, onesprite are actually 4)
    ADD HL, BC               ; HL = HL + BC
    call SetVramWrite
    ld   a, $D8              ; Y=$D8 = terminator
    out ($98), a
    ret