
;; BIOS Calls
    .global CHGMOD
    .equ CHGMOD, 0x005F            ; Zet de screen mode en wis scherm. Input: a: screen mode. Output: niets.
    .global INITXT
    .equ INITXT, 0x006C            ; Initialiseert de VDP voor de tekstmodus (40x24 karakters) en wist het scherm.

;; Memory
    .global CALSLT
    .equ CALSLT, 0x001C            ; Inter-slot calls. Input: IYh: SlotId, IYl:0, IX:doeladres.
    .global EXTBIO
    .equ EXTBIO, 0xFFCA            ; Extended BIOS (ex: memory mapper of msx-dos2)
    .global MAPTBL
    .equ MAPTBL, 0xF247            ; MSX-DOS 2 memory map table.
    .global EXPTBL
    .equ EXPTBL, 0xFCC1            ; Expanded slots table.

;; Display
    .global VDPD
    .equ VDPD, 0x98                ; VDP Data port      (lees en schrijf data)
    .global VDPC
    .equ VDPC, 0x99                ; VDP Control Port   (instellen vram adres, schrijf registers R0-R7, lees status S0-)
    .global VDPP
    .equ VDPP, 0x9A                ; VDP Pallette poort (instellen kleuren: 2x R/B en dan G)
    .global VDPR
    .equ VDPR, 0x9B                ; VDP Registers      (schrijf resisters R8-46 via r17, en sturen pixeldata voor commandos)

;; Keyboard
    .global CHPUT
    .equ CHPUT, 0x00A2             ; Print een karacter op het scherm. Input: a: karacter code. Output: niets.
    .global CHGET
    .equ CHGET, 0x009F             ; Wacht en lees een karacter van het toetsenbord. Input: niets. Output: a: karacter code.
    .global CHSNS
    .equ CHSNS, 0x009C             ; Lees de status van het toetsenbord. Input: niets. Output: Zero flag: 0 = er is een toets ingedrukt, 1 = er is geen toets ingedrukt.
    .global SNSMAT
    .equ SNSMAT, 0x0141            ; Lees de status van de keyboard matrix. Input: a: te lezen rij. Output: a: status van rij. Zie info.txt

;; Diskdrive            ; altijd met calslt!
    .global PHYDIO
    .equ PHYDIO, 0x4010            ; Fysieke schijf I/O. Zie info.txt

;; Interrupts/time
    .global JIFFY
    .equ JIFFY, 0xFC9E             ; address van nr of interrupts (50 or 60 per sec)
    .global MSXID
    .equ MSXID, 0x002B             ; de ID byte bit 7 heeft snelheid aan 50/60 hertz)

;; MSX-DOS 1/2
    .global BDOS
    .equ BDOS, 0x0005              ; dos calls

